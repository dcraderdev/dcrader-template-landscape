---
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { v1 as co } from '../data/company';
const fonts = "https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap";
const heroBase = "/images/landscape/lawn-fresh-mowed";
const heroPreloadSrcset = `${heroBase}-320.avif 320w, ${heroBase}-640.avif 640w, ${heroBase}-1024.avif 1024w, ${heroBase}-1920.avif 1920w`;
const heroPreloadSizes = "(max-width: 900px) 100vw, 50vw";
---

<LandscapeLayout
  title="GreenScape Lawn & Garden — Weekly Lawn Care in Oceanside"
  description="GreenScape provides weekly mowing, fertilization, and lawn care subscriptions for homeowners across Oceanside, Vista, San Marcos, and Carlsbad."
  fonts={fonts}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    fetchpriority="high"
    type="image/avif"
    imagesrcset={heroPreloadSrcset}
    imagesizes={heroPreloadSizes}
  />

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body {
    font-family: 'Inter', sans-serif;
    background: #faf8f3;
    color: #1c2b1a;
    margin: 0;
  }
  .serif { font-family: 'IBM Plex Serif', Georgia, serif; }
  /* tokens */
  --green: #2a5f2a;
  --green-mid: #3d7a3d;
  --green-light: #d4ecd4;
  --cream: #faf8f3;
  --cream-dark: #f0ebe0;
  --gold: #c8a84b;
  --text: #1c2b1a;
  --muted: #637063;
  --border: #dde8dd;

  .btn-green {
    display: inline-block;
    background: #2a5f2a;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.18s;
    border: none;
    cursor: pointer;
  }
  .btn-green:hover { background: #1e4a1e; }
  .btn-outline {
    display: inline-block;
    background: transparent;
    color: #2a5f2a;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.8rem 1.75rem;
    border-radius: 6px;
    border: 2px solid #2a5f2a;
    text-decoration: none;
    transition: all 0.18s;
  }
  .btn-outline:hover { background: #2a5f2a; color: #fff; }
  .label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #3d7a3d;
    margin-bottom: 0.6rem;
  }
  .card {
    background: #fff;
    border: 1px solid #dde8dd;
    border-radius: 12px;
    padding: 1.75rem;
  }
  .plan-card {
    background: #fff;
    border: 2px solid #dde8dd;
    border-radius: 16px;
    padding: 2rem;
  }
  .plan-card.featured {
    border-color: #2a5f2a;
    position: relative;
  }
  .plan-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: #2a5f2a;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    border-radius: 99px;
    white-space: nowrap;
  }
  .star { color: #f5a623; }
  .check { color: #2a5f2a; font-weight: 700; }
  section { padding: 5rem 1.5rem; }
  .inner { max-width: 72rem; margin: 0 auto; }
  .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
</style>

<!-- NAV -->
<header style="background:#fff; border-bottom:1px solid #dde8dd; position:sticky; top:0; z-index:50; padding-top:35px;">
  <nav aria-label="Main navigation" style="max-width:72rem; margin:0 auto; padding:1rem 1.5rem; display:flex; align-items:center; justify-content:space-between;">
    <a href="#" style="text-decoration:none; display:flex; align-items:center; gap:0.6rem;">
      <span style="width:34px;height:34px;background:#2a5f2a;border-radius:8px;display:flex;align-items:center;justify-content:center;" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M12 2C6.48 2 2 6.48 2 12c0 3.69 1.97 6.93 4.93 8.65"/><path d="M12 2c5.52 0 10 4.48 10 10a9.97 9.97 0 01-4.93 8.65"/><path d="M12 12c0 3-1.5 5.5-4 7"/><path d="M12 12c0 3 1.5 5.5 4 7"/></svg>
      </span>
      <span class="serif" style="font-size:1.2rem; font-weight:700; color:#1c2b1a;">GreenScape</span>
    </a>
    <div style="display:flex; gap:1.75rem; align-items:center;">
      <a href="#services" style="color:#637063; text-decoration:none; font-size:0.88rem; font-weight:500;">Services</a>
      <a href="#plans" style="color:#637063; text-decoration:none; font-size:0.88rem; font-weight:500;">Plans</a>
      <a href="#about" style="color:#637063; text-decoration:none; font-size:0.88rem; font-weight:500;">About</a>
      <a href="#contact" class="btn-green" style="padding:0.55rem 1.3rem; font-size:0.875rem;">Get a Free Quote</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO — split layout -->
<section style="padding:0; background:#faf8f3; min-height:88vh; display:grid; grid-template-columns:1fr 1fr; align-items:stretch;" aria-label="Hero">
  <!-- Left: text -->
  <div style="display:flex; flex-direction:column; justify-content:center; padding:5rem 4rem 5rem 6rem; gap:1.5rem; background:#faf8f3;">
    <div style="display:flex; align-items:center; gap:0.5rem;">
      <span style="background:#d4ecd4; color:#2a5f2a; font-size:0.72rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:0.3rem 0.85rem; border-radius:99px;">Serving Oceanside since 2004</span>
    </div>
    <h1 class="serif" style="font-size:clamp(2.4rem,4.5vw,3.75rem); line-height:1.12; color:#1c2b1a; font-weight:700;">
      Get your<br /><em style="color:#2a5f2a; font-style:italic;">Saturdays</em><br />back.
    </h1>
    <p style="font-size:1.05rem; line-height:1.75; color:#637063; max-width:28rem;">
      Weekly mowing, edging, and fertilization — handled by your dedicated neighborhood crew. Subscribe once, forget about it.
    </p>
    <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:0.5rem;">
      <a href="#plans" class="btn-green">See Lawn Plans</a>
      <a href="#contact" class="btn-outline">Get Free Quote</a>
    </div>
    <!-- Social proof strip -->
    <div style="display:flex; align-items:center; gap:1.25rem; margin-top:1rem; padding-top:1.5rem; border-top:1px solid #dde8dd;">
      <div style="display:flex; align-items:center; gap:0.25rem;" aria-label="4.9 out of 5 stars">
        <span class="star" aria-hidden="true">★★★★★</span>
        <span style="font-weight:700; font-size:0.9rem; color:#1c2b1a;">4.9</span>
        <span style="color:#637063; font-size:0.82rem;">(312 reviews)</span>
      </div>
      <span style="color:#dde8dd;">|</span>
      <span style="color:#637063; font-size:0.82rem;">1,400+ happy neighbors</span>
    </div>
  </div>
  <!-- Right: photo -->
  <div style="position:relative; overflow:hidden;">
    <ResponsiveImage
      src="/images/landscape/lawn-fresh-mowed.jpg"
      alt="Lush green residential lawn freshly mowed"
      width={900} height={700}
      sizes="(max-width: 900px) 100vw, 50vw"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      style="width:100%; height:100%; object-fit:cover; display:block;"
    />
    <div style="position:absolute; bottom:2rem; left:2rem; background:#fff; border-radius:12px; padding:1rem 1.25rem; box-shadow:0 8px 24px rgba(0,0,0,0.12); display:flex; align-items:center; gap:0.75rem;">
      <span style="font-size:2rem;" aria-hidden="true">🌿</span>
      <div>
        <p style="font-weight:700; font-size:0.88rem; margin:0; color:#1c2b1a;">Your crew arrives Thursdays</p>
        <p style="color:#637063; font-size:0.78rem; margin:0;">Consistent. Rain or shine.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section style="background:#f0ebe0; padding:4rem 1.5rem;">
  <div class="inner" style="text-align:center;">
    <span class="label">Simple as 1-2-3</span>
    <h2 class="serif" style="font-size:2.25rem; margin:0 0 2.5rem;">How GreenScape works</h2>
    <div class="grid-3">
      {[
        { n:'01', icon:'📋', title:'Pick your plan', body:'Choose Basic, Standard, or Premium. No contracts, cancel anytime.' },
        { n:'02', icon:'📅', title:'We schedule your crew', body:'A dedicated 2-person crew is assigned to your address and shows up every week.' },
        { n:'03', icon:'✉️', title:'Get a visit report', body:'After each visit you receive a text with what was done and a photo of your lawn.' },
      ].map(s => (
        <div class="card" style="text-align:left; position:relative;">
          <span style="position:absolute; top:1.25rem; right:1.5rem; font-size:2.25rem; opacity:0.08; font-family:'IBM Plex Serif',serif; font-weight:700;">{s.n}</span>
          <div style="font-size:2rem; margin-bottom:0.75rem;" aria-hidden="true">{s.icon}</div>
          <h3 style="font-weight:700; font-size:1.05rem; margin-bottom:0.4rem;">{s.title}</h3>
          <p style="color:#637063; font-size:0.9rem; line-height:1.65; margin:0;">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SUBSCRIPTION PLANS — featured section -->
<section id="plans" aria-labelledby="plans-h" style="background:#fff; padding:5rem 1.5rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">Weekly Lawn Plans</span>
      <h2 id="plans-h" class="serif" style="font-size:2.75rem; margin:0.25rem 0 0.75rem;">Subscribe and forget about it</h2>
      <p style="color:#637063; max-width:36rem; margin:0 auto; line-height:1.7;">All plans include weekly mowing, edging, and blowing. No contracts — pause or cancel any month.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.5rem; align-items:start;">
      {co.plans.map((p,i) => (
        <div class={`plan-card${i===1?' featured':''}`} style="position:relative;">
          {i===1 && <span class="plan-badge">Most Popular</span>}
          <p class="label" style={i===1?'color:#2a5f2a;':''}>{p.name} Plan</p>
          <div style="display:flex; align-items:baseline; gap:0.25rem; margin:0.5rem 0 0.25rem;">
            <span class="serif" style={`font-size:3rem; font-weight:700; ${i===1?'color:#2a5f2a;':'color:#1c2b1a;'}`}>{p.price}</span>
            <span style="color:#637063; font-size:0.9rem;">{p.period}</span>
          </div>
          <p style="color:#637063; font-size:0.8rem; margin:0 0 1.25rem;">billed monthly, no contract</p>
          <ul style="list-style:none; padding:0; margin:0 0 1.75rem; display:flex; flex-direction:column; gap:0.6rem;">
            {p.features.map(f => (
              <li style="display:flex; gap:0.6rem; font-size:0.9rem; align-items:flex-start;">
                <span class="check" aria-hidden="true" style="flex-shrink:0; margin-top:0.05em;">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contact" class="btn-green" style={`display:block; text-align:center; ${i===1?'':'background:#f0ebe0; color:#2a5f2a;'}`}>
            Start {p.name}
          </a>
        </div>
      ))}
    </div>
    <p style="text-align:center; color:#637063; font-size:0.82rem; margin-top:2rem;">Prices include all labor and disposal. One-time setup: free. Cancel anytime by text.</p>
  </div>
</section>

<!-- SERVICES GRID -->
<section id="services" aria-labelledby="svc-h" style="background:#faf8f3; padding:5rem 1.5rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">What's included</span>
      <h2 id="svc-h" class="serif" style="font-size:2.5rem; margin:0.25rem 0 0;">All the lawn care you need</h2>
    </div>
    <div class="grid-3">
      {co.services.map(s => (
        <div class="card">
          <span style="font-size:2rem;" aria-hidden="true">{s.icon}</span>
          <h3 style="font-weight:700; margin:0.75rem 0 0.35rem; font-size:1rem;">{s.title}</h3>
          <p style="color:#637063; font-size:0.88rem; line-height:1.6; margin:0;">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BEFORE/AFTER -->
<section aria-labelledby="ba-h" style="background:#f0ebe0; padding:5rem 1.5rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <span class="label">Results</span>
      <h2 id="ba-h" class="serif" style="font-size:2.25rem; margin:0.25rem 0;">Real lawns. Real transformations.</h2>
    </div>
    <div class="grid-2">
      {co.beforeAfter.map(ba => (
        <div class="card" style="padding:0; overflow:hidden;">
          <div style="display:grid; grid-template-columns:1fr 1fr;">
            <div style="position:relative;">
              <ResponsiveImage src={ba.before} alt={`Before: ${ba.label}`} width={300} height={220} sizes="(max-width: 768px) 50vw, 300px" loading="lazy" style="width:100%; height:180px; object-fit:cover; display:block;" />
              <span style="position:absolute; bottom:0.5rem; left:0.5rem; background:rgba(0,0,0,0.55); color:#fff; font-size:0.68rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:0.25rem 0.6rem; border-radius:4px;">Before</span>
            </div>
            <div style="position:relative;">
              <ResponsiveImage src={ba.after} alt={`After: ${ba.label}`} width={300} height={220} sizes="(max-width: 768px) 50vw, 300px" loading="lazy" style="width:100%; height:180px; object-fit:cover; display:block;" />
              <span style="position:absolute; bottom:0.5rem; left:0.5rem; background:#2a5f2a; color:#fff; font-size:0.68rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:0.25rem 0.6rem; border-radius:4px;">After</span>
            </div>
          </div>
          <div style="padding:1rem 1.25rem;">
            <p style="font-weight:700; font-size:0.9rem; margin:0; color:#1c2b1a;">{ba.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PORTFOLIO -->
<section id="portfolio" aria-labelledby="port-h" style="background:#fff; padding:5rem 1.5rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <span class="label">Portfolio</span>
      <h2 id="port-h" class="serif" style="font-size:2.25rem; margin:0.25rem 0;">Lawns we're proud of</h2>
    </div>
    <div class="grid-3">
      {co.portfolio.map(p => (
        <figure style="margin:0; border-radius:12px; overflow:hidden; border:1px solid #dde8dd;">
          <ResponsiveImage src={p.img} alt={p.title} width={600} height={380} sizes="(max-width: 768px) 100vw, 33vw" loading="lazy" style="width:100%; height:200px; object-fit:cover; display:block;" />
          <figcaption style="padding:1rem 1.25rem; background:#fff;">
            <p style="font-weight:700; font-size:0.9rem; margin:0 0 0.3rem;">{p.title}</p>
            <p style="color:#637063; font-size:0.82rem; margin:0; line-height:1.5;">{p.description}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- HOMEOWNER STORY — pull quote with photo -->
<section aria-labelledby="story-h" style="background:#2a5f2a; padding:4.5rem 1.5rem;">
  <div class="inner" style="display:grid; grid-template-columns:minmax(0,260px) 1fr; gap:2.5rem; align-items:center;">
    <div style="position:relative;">
      <ResponsiveImage
        src="/images/landscape/lawn-fresh-mowed.jpg"
        alt="The Hartwell family's restored front lawn in Oceanside"
        width={520}
        height={520}
        sizes="(max-width: 768px) 100vw, 260px"
        loading="lazy"
        style="width:100%; aspect-ratio:1/1; object-fit:cover; border-radius:12px; display:block; border:4px solid rgba(255,255,255,0.15);"
      />
      <span style="position:absolute; bottom:0.6rem; left:0.6rem; background:rgba(0,0,0,0.55); color:#fff; font-size:0.68rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:0.25rem 0.6rem; border-radius:4px;">Hartwell Residence, Oceanside</span>
    </div>
    <div>
      <span class="label" style="color:#90cc90;" id="story-h">A neighbor's story</span>
      <p class="serif" style="font-size:1.6rem; line-height:1.45; color:#fff; margin:0.6rem 0 1.5rem; font-style:italic;">
        &ldquo;Mike and the GreenScape crew turned our patchy Bermuda into something the whole block notices. Two seasons in, the lawn looks better than the day we moved in&nbsp;&mdash; and I haven't pulled a sprinkler head once.&rdquo;
      </p>
      <div style="display:flex; align-items:center; gap:0.85rem;">
        <span aria-hidden="true" style="width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,#90cc90,#4a9e4a); display:flex; align-items:center; justify-content:center; color:#1c2b1a; font-family:'IBM Plex Serif',Georgia,serif; font-weight:700; font-size:1.15rem;">D</span>
        <div>
          <p style="font-weight:700; color:#fff; font-size:0.95rem; margin:0;">Dana Hartwell</p>
          <p style="color:rgba(255,255,255,0.7); font-size:0.8rem; margin:0;">Homeowner since 2022 &middot; Standard Plan</p>
        </div>
      </div>
      <div style="margin-top:1.75rem; display:flex; flex-wrap:wrap; gap:0.5rem;">
        {co.certifications.map(c => (
          <span style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); color:#fff; font-size:0.72rem; font-weight:600; padding:0.3rem 0.75rem; border-radius:99px;">{c}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TEAM -->
<section id="about" aria-labelledby="team-h" style="background:#faf8f3; padding:5rem 1.5rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <span class="label">The neighborhood crew</span>
      <h2 id="team-h" class="serif" style="font-size:2.25rem; margin:0.25rem 0;">Meet the GreenScape team</h2>
      <p style="color:#637063; max-width:30rem; margin:0.75rem auto 0; line-height:1.65;">We're your neighbors. We live in the communities we serve — and it shows.</p>
    </div>
    <div class="grid-3" style="grid-template-columns:repeat(auto-fit,minmax(190px,1fr));">
      {co.teamMembers.map(m => (
        <div class="card" style="text-align:center;">
          <div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,#3d7a3d,#2a5f2a); margin:0 auto 1rem; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
            <span class="serif" style="color:#fff; font-size:1.75rem; font-weight:700;">{m.name[0]}</span>
          </div>
          <p style="font-weight:700; font-size:0.95rem; margin:0 0 0.2rem;">{m.name}</p>
          <p style="color:#637063; font-size:0.82rem; margin:0;">{m.role}</p>
          {m.cert && <p style="color:#2a5f2a; font-size:0.75rem; font-weight:600; margin:0.35rem 0 0;">{m.cert}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section style="background:#f0ebe0; padding:4rem 1.5rem;">
  <div class="inner" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2.5rem; align-items:center;">
    <div>
      <span class="label">Service area</span>
      <h2 class="serif" style="font-size:2rem; margin:0.5rem 0 1rem;">We come to you</h2>
      <p style="color:#637063; line-height:1.7; margin-bottom:1.25rem;">Serving homeowners across North San Diego County:</p>
      <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem;">
        {co.serviceArea.split(', ').map(a => (
          <li style="display:flex; align-items:center; gap:0.5rem; font-size:0.92rem;">
            <span style="color:#2a5f2a;" aria-hidden="true">📍</span> {a}
          </li>
        ))}
      </ul>
    </div>
    <div style="background:#fff; border:1px solid #dde8dd; border-radius:14px; height:280px; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:0.6rem;">
      <span style="font-size:3rem;" aria-hidden="true">🗺️</span>
      <p style="font-weight:700; color:#1c2b1a; margin:0; font-size:0.95rem;">North San Diego County</p>
      <p style="color:#637063; font-size:0.82rem; margin:0; text-align:center; padding:0 1.5rem;">{co.serviceArea}</p>
    </div>
  </div>
</section>

<!-- ESTIMATE FORM -->
<section id="contact" aria-labelledby="contact-h" style="background:#1c2b1a; padding:5rem 1.5rem;">
  <div style="max-width:44rem; margin:0 auto; text-align:center;">
    <span class="label" style="color:#90cc90;">Free estimate</span>
    <h2 id="contact-h" class="serif" style="color:#fff; font-size:2.5rem; margin:0.4rem 0 0.75rem;">What's your address?</h2>
    <p style="color:rgba(255,255,255,0.65); margin-bottom:2.5rem; line-height:1.7;">We'll pull up satellite view, measure your lawn, and email a quote — usually in under an hour.</p>
    <form novalidate aria-label="Free estimate form" style="display:grid; gap:0.9rem; text-align:left;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.9rem;">
        <div>
          <label for="v1-fn" style="color:rgba(255,255,255,0.75); font-size:0.8rem; font-weight:600; display:block; margin-bottom:0.35rem;">First name <span aria-hidden="true">*</span></label>
          <input id="v1-fn" name="first_name" type="text" required autocomplete="given-name" placeholder="Jane" style="width:100%; padding:0.75rem; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.07); color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif;" />
        </div>
        <div>
          <label for="v1-ln" style="color:rgba(255,255,255,0.75); font-size:0.8rem; font-weight:600; display:block; margin-bottom:0.35rem;">Last name <span aria-hidden="true">*</span></label>
          <input id="v1-ln" name="last_name" type="text" required autocomplete="family-name" placeholder="Smith" style="width:100%; padding:0.75rem; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.07); color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif;" />
        </div>
      </div>
      <div>
        <label for="v1-addr" style="color:rgba(255,255,255,0.75); font-size:0.8rem; font-weight:600; display:block; margin-bottom:0.35rem;">Street address <span aria-hidden="true">*</span></label>
        <input id="v1-addr" name="address" type="text" required autocomplete="street-address" placeholder="123 Oak Lane, Oceanside, CA" style="width:100%; padding:0.75rem; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.07); color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif;" />
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.9rem;">
        <div>
          <label for="v1-email" style="color:rgba(255,255,255,0.75); font-size:0.8rem; font-weight:600; display:block; margin-bottom:0.35rem;">Email <span aria-hidden="true">*</span></label>
          <input id="v1-email" name="email" type="email" required autocomplete="email" placeholder="jane@example.com" style="width:100%; padding:0.75rem; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.07); color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif;" />
        </div>
        <div>
          <label for="v1-plan" style="color:rgba(255,255,255,0.75); font-size:0.8rem; font-weight:600; display:block; margin-bottom:0.35rem;">Plan interest</label>
          <select id="v1-plan" name="plan" style="width:100%; padding:0.75rem; border-radius:6px; border:1px solid rgba(255,255,255,0.15); background:rgba(28,43,26,0.95); color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif;">
            <option value="">Not sure yet…</option>
            {co.plans.map(p => <option value={p.name}>{p.name} — {p.price}{p.period}</option>)}
          </select>
        </div>
      </div>
      <button type="submit" class="btn-green" style="width:100%; padding:1rem; font-size:1rem; border-radius:6px; margin-top:0.25rem;">Get My Free Quote →</button>
    </form>
    <p style="color:rgba(255,255,255,0.35); font-size:0.78rem; margin-top:1.25rem;">Or call us: <a href={`tel:${co.phone.replace(/\D/g,'')}`} style="color:rgba(255,255,255,0.55);">{co.phone}</a></p>
  </div>
</section>

</main>

<!-- FOOTER -->
<footer style="background:#111a10; color:rgba(255,255,255,0.5); padding:2.5rem 1.5rem; text-align:center;">
  <div style="max-width:72rem; margin:0 auto; display:flex; flex-direction:column; gap:0.5rem; align-items:center;">
    <span class="serif" style="color:#90cc90; font-size:1.1rem; font-weight:700;">GreenScape Lawn &amp; Garden</span>
    <p style="font-size:0.8rem; margin:0;">{co.address} · <a href={`tel:${co.phone.replace(/\D/g,'')}`} style="color:rgba(255,255,255,0.5);">{co.phone}</a></p>
    <p style="font-size:0.75rem; margin:0;">&copy; {new Date().getFullYear()} GreenScape Lawn &amp; Garden. CA Licensed C-27. All rights reserved.</p>
    <p style="font-size:0.75rem; margin:0;"><a href="/accessibility" style="color:rgba(255,255,255,0.75); text-decoration:underline;">Accessibility Statement</a></p>
    <p style="font-size:0.72rem; margin:0; color:rgba(255,255,255,0.35);">Built by <a href="https://dcrader.dev" style="color:rgba(255,255,255,0.55); text-decoration:underline;">Donovan Crader · dcrader.dev</a></p>
  </div>
</footer>

</LandscapeLayout>
