        <p style="font-size:0.66rem; letter-spacing:0.18em; text-transform:uppercase; color:#c8d8a0; margin:0 0 0.6rem;">Visit / read</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.3rem; font-size:0.78rem;">
          <li><a href="#services" style="color:rgba(255,255,255,0.55); text-decoration:none;">Services</a></li>
          <li><a href="#work" style="color:rgba(255,255,255,0.55); text-decoration:none;">Garden stories</a></li>
          <li><a href="#contact" style="color:rgba(255,255,255,0.55); text-decoration:none;">Book a site walk</a></li>
