---
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
---
<LandscapeLayout title="Accessibility Statement" description="Accessibility statement and WCAG 2.1 AA compliance commitment.">
  <main id="main-content" style="max-width:48rem; margin:0 auto; padding:4rem 1.5rem; font-family:system-ui, -apple-system, sans-serif; line-height:1.6; color:#1a1a1a;">
    <h1 style="font-size:2rem; font-weight:700; margin-bottom:1.5rem;">Accessibility Statement</h1>
    <p style="margin-bottom:1rem;">This site is committed to ensuring digital accessibility for people of all abilities. We strive to conform to WCAG 2.1 Level AA standards. If you experience difficulty accessing any part of this site, please contact us.</p>
    <p style="margin-bottom:1rem; color:#444;">Last updated: 2026-05-17</p>
  </main>
  <footer style="border-top:1px solid #e5e7eb; padding:1.5rem; text-align:center; color:#6b7280; font-size:0.78rem;">
    <p>Built by <a href="https://dcrader.dev" style="color:#374151; text-decoration:underline;">Donovan Crader · dcrader.dev</a></p>
  </footer>
</LandscapeLayout>
