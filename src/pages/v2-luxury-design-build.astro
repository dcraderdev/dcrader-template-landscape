---
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import PortfolioGalleryHero from '../components/landscape/PortfolioGalleryHero.astro';
import { v2 as co } from '../data/company';
const fonts = "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap";

const projects = [
  { name: "Casa Cielo — Rancho Santa Fe", scope: "2.4-acre formal garden, reflecting pool, rose parterre, bespoke water feature", value: "$420,000", img: "/images/landscape/formal-estate.jpg", year: "2023" },
  { name: "Villa del Mar — La Jolla Shores", scope: "Blufftop infinity terrace, sculptural agave garden, specimen olive grove", value: "$285,000", img: "/images/landscape/coastal-blufftop.jpg", year: "2024" },
  { name: "The Whitmore Estate — Del Mar", scope: "French parterre, boxwood allées, croquet lawn, custom pergola dining", value: "$340,000", img: "/images/landscape/lawn-fresh-mowed.jpg", year: "2023" },
];

// Hero gallery: pull all available estate imagery for the 2x3 tile grid.
const heroGalleryItems = [
  { title: 'Casa Cielo — Rancho Santa Fe', img: '/images/landscape/formal-estate.jpg', year: '2023' },
  { title: 'Villa del Mar — La Jolla Shores', img: '/images/landscape/coastal-blufftop.jpg', year: '2024' },
  { title: 'The Whitmore Estate — Del Mar', img: '/images/landscape/lawn-fresh-mowed.jpg', year: '2023' },
  { title: 'Hartwell Garden Wing', img: '/images/landscape/lawn-renovation.jpg', year: '2024' },
  { title: 'Coronado Courtyard', img: '/images/landscape/wild-meadow.jpg', year: '2022' },
  { title: 'Sunrise Estates Pavilion', img: '/images/landscape/sunrise-estates.jpg', year: '2023' },
];

const testimonials = [
  { quote: "Meridian transformed our property into something we never thought possible. Every detail was considered, every plant chosen with intention.", name: "Catherine R.", location: "Rancho Santa Fe" },
  { quote: "The team understood our vision before we could articulate it. Working with them was effortless and the result is extraordinary.", name: "James & Priya W.", location: "La Jolla" },
];
---

<LandscapeLayout
  title="Meridian Design + Build — Luxury Landscape Studio, La Jolla"
  description="Meridian Design + Build creates singular estate gardens across La Jolla, Rancho Santa Fe, Del Mar, and Coronado. Bespoke design. Enduring legacy."
  fonts={fonts}
>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: #f9f7f2; color: #1e2b1e; margin: 0; }
  .garam { font-family: 'Cormorant Garamond', Georgia, serif; }

  /* color tokens */
  :root {
    --sage: #2e4a2e;
    --sage-mid: #3d5c3d;
    --champ: #c8a96a;
    --champ-light: #f0e8d0;
    --bg: #f9f7f2;
    --bg2: #f3ede1;
    --text: #1e2b1e;
    --muted: #7a7a6a;
    --rule: #d8cfa8;
  }

  .btn-inquire {
    display: inline-block;
    background: var(--champ, #c8a96a);
    color: #1e2b1e;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.18s;
    border: none;
    cursor: pointer;
  }
  .btn-inquire:hover { opacity: 0.85; }
  .btn-ghost {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.35);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: background 0.18s;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); }
  .rule { width: 48px; height: 1px; background: #c8a96a; }
  .label-sm {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c8a96a;
  }
  hr.divider { border: none; border-top: 1px solid #d8cfa8; margin: 0; }
</style>

<!-- NAV -->
<header style="background: rgba(30,42,30,0.97); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 50; border-bottom: 1px solid rgba(200,169,106,0.18); padding-top: 35px;">
  <nav aria-label="Main navigation" style="max-width:88rem; margin:0 auto; padding:1.4rem 3rem; display:flex; align-items:center; justify-content:space-between;">
    <a href="#" style="text-decoration:none;">
      <span class="label-sm" style="color:#c8a96a; display:block; letter-spacing:0.25em;">Meridian</span>
      <span style="color:rgba(255,255,255,0.45); font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; display:block; margin-top:1px;">Design + Build · Est. {co.founded}</span>
    </a>
    <div style="display:flex; gap:2.5rem; align-items:center;">
      {['Services','Portfolio','Studio'].map(l => (
        <a href={`#${l.toLowerCase()}`} style="color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.82rem; letter-spacing:0.06em; font-weight:300; transition:color 0.18s;" onmouseover="this.style.color='rgba(255,255,255,0.95)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">{l}</a>
      ))}
      <a href="#contact" class="btn-inquire" style="padding:0.7rem 1.75rem;">Inquire</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO — portfolio gallery (variant 2) -->
<PortfolioGalleryHero
  brand={co.name}
  eyebrow="Selected estate work · La Jolla"
  headline="Where landscape"
  headlineEm="becomes legacy."
  body="A design-build studio creating estate gardens of singular beauty for discerning clients across coastal San Diego."
  items={heroGalleryItems}
  ctaPrimary={{ href: '#contact', label: 'Begin your project' }}
  ctaSecondary={{ href: '#portfolio', label: 'View full portfolio' }}
/>

<!-- SIGNATURE INSTALLATION — featured project plate -->
<section aria-labelledby="signature-h" style="background:#1e2b1e; padding:5rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:grid; grid-template-columns:1.15fr 1fr; gap:0; align-items:stretch; border:1px solid rgba(200,169,106,0.18);">
    <figure style="margin:0; position:relative; min-height:420px; overflow:hidden;">
      <ResponsiveImage
        src="/images/landscape/formal-estate.jpg"
        alt="Reflecting pool and parterre at the Rancho Santa Fe estate garden"
        width={1100}
        height={780}
        sizes="(max-width: 1024px) 100vw, 50vw"
        loading="lazy"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;"
      />
      <figcaption style="position:absolute; bottom:1.25rem; left:1.25rem; color:rgba(255,255,255,0.85); font-size:0.7rem; letter-spacing:0.16em; text-transform:uppercase; background:rgba(0,0,0,0.45); padding:0.4rem 0.85rem; border-left:2px solid #c8a96a;">Plate 01 &mdash; Photograph by studio</figcaption>
    </figure>
    <div style="padding:3.5rem 3rem; display:flex; flex-direction:column; justify-content:center; background:#1a2618;">
      <p style="color:#c8a96a; font-size:0.7rem; font-weight:500; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1.25rem;" id="signature-h">Signature installation</p>
      <h3 class="garam" style="color:#fff; font-size:2.25rem; font-weight:400; line-height:1.15; margin:0 0 0.5rem;">Rancho Santa Fe<br /><em>Reflecting Garden</em></h3>
      <div style="width:48px; height:1px; background:#c8a96a; margin:1.25rem 0 1.5rem;"></div>
      <p style="color:rgba(255,255,255,0.7); font-size:0.92rem; line-height:1.85; font-weight:300; margin:0 0 1.75rem;">
        Two acres of formal parterre, a hand-laid Connecticut bluestone terrace, and a 60-foot reflecting pool that mirrors the Cleveland sage hedge at dusk. Twenty-two months from first sketch to final planting&mdash;and the rose garden is just beginning its second bloom cycle.
      </p>
      <dl style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem 2rem; margin:0; color:#fff;">
        <div>
          <dt style="color:rgba(255,255,255,0.45); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; margin-bottom:0.35rem;">Site</dt>
          <dd style="margin:0; font-size:0.88rem; font-weight:400;">2.1 acres &middot; Rancho Santa Fe</dd>
        </div>
        <div>
          <dt style="color:rgba(255,255,255,0.45); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; margin-bottom:0.35rem;">Disciplines</dt>
          <dd style="margin:0; font-size:0.88rem; font-weight:400;">Masterplan, hardscape, water, lighting</dd>
        </div>
        <div>
          <dt style="color:rgba(255,255,255,0.45); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; margin-bottom:0.35rem;">Completed</dt>
          <dd style="margin:0; font-size:0.88rem; font-weight:400;">Spring 2024</dd>
        </div>
        <div>
          <dt style="color:rgba(255,255,255,0.45); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; margin-bottom:0.35rem;">Stewardship</dt>
          <dd style="margin:0; font-size:0.88rem; font-weight:400;">Estate plan, weekly visits</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<!-- SERVICES — numbered editorial list -->
<section id="services" aria-labelledby="svc-h" style="background:#f9f7f2; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:grid; grid-template-columns:280px 1fr; gap:6rem; align-items:start;">
    <div style="position:sticky; top:6rem;">
      <p class="label-sm" style="margin-bottom:1rem;">Studio expertise</p>
      <h2 id="svc-h" class="garam" style="font-size:3rem; font-weight:400; line-height:1.1; margin:0 0 1.5rem;">Our<br /><em>services</em></h2>
      <div class="rule"></div>
      <p style="color:#7a7a6a; margin-top:1.25rem; line-height:1.8; font-size:0.9rem; font-weight:300;">From first sketch to seasonal stewardship — we manage every detail of your outdoor legacy.</p>
    </div>
    <div>
      {co.services.map((s, i) => (
        <div>
          {i > 0 && <hr class="divider" />}
          <div style={`display:grid; grid-template-columns:60px 1fr; gap:2rem; align-items:start; padding:2.5rem 0;`}>
            <span class="garam" style="font-size:3.5rem; font-weight:300; color:#d8cfa8; line-height:1;">{String(i+1).padStart(2,'0')}</span>
            <div>
              <h3 style="font-size:1.2rem; font-weight:500; margin:0 0 0.6rem; color:#1e2b1e; letter-spacing:0.01em;">{s.title}</h3>
              <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; margin:0; font-weight:300;">{s.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PORTFOLIO — large editorial -->
<section id="portfolio" aria-labelledby="port-h" style="background:#f3ede1; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:4rem; padding-bottom:1.5rem; border-bottom:1px solid #d8cfa8;">
      <div>
        <p class="label-sm">Selected work</p>
        <h2 id="port-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0 0;">Portfolio</h2>
      </div>
      <p style="color:#7a7a6a; font-size:0.82rem; font-weight:300;">2023 — 2024</p>
    </div>
    {projects.map((p, i) => (
      <div>
        {i > 0 && <hr class="divider" style="margin:0;" />}
        <div style={`display:grid; grid-template-columns:${i%2===0?'5fr 4fr':'4fr 5fr'}; gap:0; min-height:480px; ${i>0?'':'border-top:1px solid #d8cfa8;'}`}>
          <div style={`overflow:hidden; ${i%2===1?'order:1;':''}`}>
            <ResponsiveImage src={p.img} alt={p.name} width={900} height={600} sizes="(max-width: 1024px) 100vw, 50vw" loading="lazy" style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.6s ease;" />
          </div>
          <div style={`padding:3.5rem; display:flex; flex-direction:column; justify-content:center; background:${i%2===0?'#fff':'#f9f7f2'}; ${i%2===1?'order:0;':''}`}>
            <p class="label-sm" style="margin-bottom:1.25rem;">{p.year}</p>
            <h3 class="garam" style="font-size:2rem; font-weight:400; margin:0 0 1.25rem; line-height:1.2;">{p.name}</h3>
            <div class="rule" style="margin-bottom:1.25rem;"></div>
            <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; font-weight:300; margin-bottom:1.75rem;">{p.scope}</p>
            <p style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#c8a96a; font-weight:500;">Project investment: {p.value}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- PROCESS — A studio's seven movements (replaces generic B/A) -->
<section aria-labelledby="ba-h" style="background:#f9f7f2; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:4rem; align-items:start; margin-bottom:4rem;">
      <div>
        <p class="label-sm">Studio process</p>
        <h2 id="ba-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0 1.25rem; line-height:1.05;">Seven<br/><em>movements</em></h2>
        <div class="rule"></div>
      </div>
      <p style="color:#7a7a6a; font-size:0.95rem; line-height:1.85; font-weight:300; margin:0; padding-top:0.5rem;">
        Every commission moves through a deliberate sequence&mdash;from the first walk of your land to the season we hand it over and beyond. A typical estate occupies the studio for fourteen to twenty-two months. Some longer.
      </p>
    </div>
    <ol style="list-style:none; margin:0; padding:0; counter-reset:movement;">
      {[
        { roman:'I', name:'The Walk', detail:'A half-day on your land. We sketch grade, sun arcs, sight lines, and the trees that must stay.' },
        { roman:'II', name:'The Brief', detail:'A written manifesto of the garden you want&mdash;and the one your land is asking for. Often these are different.' },
        { roman:'III', name:'Conceptual Plan', detail:'Hand-rendered masterplan in watercolor and pencil. Presented in our La Jolla studio over an unhurried morning.' },
        { roman:'IV', name:'Construction Documents', detail:'CAD, grading, irrigation, lighting, planting palettes. Drawings precise enough that the masonry contractor never has to call.' },
        { roman:'V', name:'Build', detail:'Our own crews, our own equipment yard. Single point of accountability through inspection.' },
        { roman:'VI', name:'Planting & Lighting', detail:'Specimen trees first, sourced from California growers. Lighting calibrated by hand after dark on three consecutive evenings.' },
        { roman:'VII', name:'Stewardship', detail:'Weekly white-glove care. Care logs, a named horticulturist, and an annual walk to keep the design intentional.' },
      ].map((m, i) => (
        <li style={`display:grid; grid-template-columns:80px 200px 1fr; gap:3rem; align-items:start; padding:2rem 0; ${i>0?'border-top:1px solid #d8cfa8;':''}`}>
          <span class="garam" style="font-size:2.5rem; font-weight:300; color:#c8a96a; line-height:1; font-style:italic;">{m.roman}</span>
          <h3 class="garam" style="font-size:1.35rem; font-weight:400; margin:0; line-height:1.15; padding-top:0.25rem;">{m.name}</h3>
          <p style="color:#7a7a6a; font-size:0.92rem; line-height:1.85; font-weight:300; margin:0.25rem 0 0; max-width:42rem;">{m.detail}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- TESTIMONIALS -->
<section style="background:#1e2b1e; padding:6rem 3rem;">
  <div style="max-width:72rem; margin:0 auto;">
    <p class="label-sm" style="text-align:center; display:block; margin-bottom:3rem;">Client words</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(340px,1fr)); gap:3rem;">
      {testimonials.map(t => (
        <div style="border-top:1px solid rgba(200,169,106,0.3); padding-top:2rem;">
          <p class="garam" style="color:rgba(255,255,255,0.88); font-size:1.2rem; font-style:italic; line-height:1.75; margin:0 0 1.5rem; font-weight:300;">"{t.quote}"</p>
          <div class="rule"></div>
          <p style="color:#c8a96a; font-size:0.82rem; margin:1rem 0 0; font-weight:500;">{t.name} <span style="color:rgba(255,255,255,0.35); font-weight:300;">— {t.location}</span></p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CERTIFICATIONS -->
<section aria-labelledby="certs-h" style="background:#f3ede1; padding:5rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:3rem; align-items:center;">
    <div>
      <p class="label-sm" style="margin-bottom:0.75rem;">Credentials</p>
      <h2 id="certs-h" class="garam" style="font-size:2.5rem; font-weight:400; margin:0 0 1.25rem;">Certified excellence</h2>
      <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; font-weight:300;">Every project is led by licensed designers with deep expertise in horticulture, construction, and estate stewardship.</p>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
      {co.certifications.map(c => (
        <span style="border:1px solid #c8a96a; color:#1e2b1e; font-size:0.82rem; font-weight:500; padding:0.55rem 1.25rem; letter-spacing:0.03em;">{c}</span>
      ))}
    </div>
  </div>
</section>

<!-- TEAM — masthead style, no avatars -->
<section id="studio" aria-labelledby="team-h" style="background:#f9f7f2; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:3.5rem; padding-bottom:1.5rem; border-bottom:1px solid #d8cfa8;">
      <div>
        <p class="label-sm">Masthead</p>
        <h2 id="team-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0 0;">The Studio</h2>
      </div>
      <p style="color:#7a7a6a; font-size:0.82rem; font-weight:300; font-style:italic;">Issue {new Date().getFullYear() - 2009}</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:0;">
      {co.teamMembers.map((m, i) => (
        <article style={`padding:2rem 1.5rem; ${i>0?'border-left:1px solid #d8cfa8;':''} ${i===0?'padding-left:0;':''}`}>
          <p class="label-sm" style="margin-bottom:1rem;">{['Direction','Craft','Horticulture','Operations'][i] || 'Studio'}</p>
          <h3 class="garam" style="font-size:1.45rem; font-weight:400; margin:0 0 0.35rem; line-height:1.15;">{m.name}</h3>
          <p style="color:#7a7a6a; font-size:0.85rem; font-weight:300; margin:0 0 0.85rem; font-style:italic;">{m.role}</p>
          {m.cert && (
            <p style="color:#1e2b1e; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; margin:0; padding-top:0.85rem; border-top:1px solid #d8cfa8; font-weight:500;">— {m.cert}</p>
          )}
        </article>
      ))}
    </div>
    <p style="color:#7a7a6a; font-size:0.82rem; font-weight:300; margin:3rem 0 0; max-width:36rem; line-height:1.85; font-style:italic;">
      Together the studio has thirty-eight years of practice. We accept four to six new commissions per calendar year.
    </p>
  </div>
</section>

<!-- CONTACT — no pricing, just inquiry -->
<section id="contact" aria-labelledby="contact-h" style="background:#f3ede1; padding:7rem 3rem;">
  <div style="max-width:52rem; margin:0 auto;">
    <div style="text-align:center; margin-bottom:4rem;">
      <p class="label-sm">Begin</p>
      <h2 id="contact-h" class="garam" style="font-size:3.5rem; font-weight:300; margin:0.5rem 0 1rem; line-height:1.1;">Start the<br /><em>conversation</em></h2>
      <div class="rule" style="margin:1.5rem auto;"></div>
      <p style="color:#7a7a6a; font-size:0.95rem; line-height:1.8; font-weight:300;">We accept a limited number of new projects each season. We would love to hear about yours.</p>
    </div>
    <form novalidate aria-label="Project inquiry form" style="display:grid; gap:1.1rem;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.1rem;">
        <div>
          <label for="v2-fn" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">First name</label>
          <input id="v2-fn" name="first_name" type="text" required autocomplete="given-name" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
        </div>
        <div>
          <label for="v2-ln" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Last name</label>
          <input id="v2-ln" name="last_name" type="text" required autocomplete="family-name" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
        </div>
      </div>
      <div>
        <label for="v2-email" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Email address</label>
        <input id="v2-email" name="email" type="email" required autocomplete="email" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
      </div>
      <div>
        <label for="v2-loc" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Property location</label>
        <input id="v2-loc" name="location" type="text" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e;" placeholder="City or neighborhood" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
      </div>
      <div>
        <label for="v2-scope" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Project scope</label>
        <select id="v2-scope" name="scope" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; appearance:auto;">
          <option value="">Please select…</option>
          {co.services.map(s => <option value={s.title}>{s.title}</option>)}
        </select>
      </div>
      <div>
        <label for="v2-vision" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Your vision</label>
        <textarea id="v2-vision" name="vision" rows={5} style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; resize:vertical;" placeholder="Tell us about your property, your aspirations, and what you hope to create…" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'"></textarea>
      </div>
      <button type="submit" class="btn-inquire" style="width:100%; padding:1.1rem; font-size:0.85rem;">Submit Inquiry</button>
    </form>
    <p style="text-align:center; color:#7a7a6a; font-size:0.78rem; margin-top:1.5rem; font-weight:300;">{co.phone} · {co.email}</p>
  </div>
</section>

</main>

<!-- FOOTER — colophon style, three columns left-aligned, sage on cream rule -->
<footer style="background:#111a11; color:rgba(255,255,255,0.5); padding:4rem 3rem 1.75rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:3rem; padding-bottom:3rem; border-bottom:1px solid rgba(200,169,106,0.25);">
      <div>
        <p class="garam" style="color:#c8a96a; font-size:1.5rem; font-weight:400; margin:0 0 0.6rem; letter-spacing:0.02em;">Meridian</p>
        <p style="font-size:0.78rem; line-height:1.7; margin:0 0 1rem; color:rgba(255,255,255,0.45); font-style:italic; max-width:20rem;">A design-build studio creating estate gardens of singular beauty.</p>
        <p style="font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:rgba(255,255,255,0.35);">Est. {co.founded}</p>
      </div>
      <div>
        <p style="font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:#c8a96a; margin:0 0 1rem;">Studio</p>
        <p style="font-size:0.82rem; line-height:1.85; margin:0; color:rgba(255,255,255,0.55);">
          {co.address.split(', ')[0]}<br/>
          {co.address.split(', ').slice(1).join(', ')}<br/>
          <span style="color:rgba(255,255,255,0.35); font-size:0.74rem;">By appointment</span>
        </p>
      </div>
      <div>
        <p style="font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:#c8a96a; margin:0 0 1rem;">Inquiries</p>
        <p style="font-size:0.82rem; line-height:1.85; margin:0; color:rgba(255,255,255,0.55);">
          <a href={`mailto:${co.email}`} style="color:rgba(255,255,255,0.7); text-decoration:none;">{co.email}</a><br/>
          <a href={`tel:${co.phone.replace(/\D/g,'')}`} style="color:rgba(255,255,255,0.7); text-decoration:none;">{co.phone}</a><br/>
          <span style="color:rgba(255,255,255,0.35); font-size:0.74rem;">Mon – Fri · 9 to 5</span>
        </p>
      </div>
      <div>
        <p style="font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:#c8a96a; margin:0 0 1rem;">Index</p>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0.4rem; font-size:0.82rem;">
          <li><a href="#services" style="color:rgba(255,255,255,0.55); text-decoration:none;">Services</a></li>
          <li><a href="#portfolio" style="color:rgba(255,255,255,0.55); text-decoration:none;">Selected work</a></li>
          <li><a href="#studio" style="color:rgba(255,255,255,0.55); text-decoration:none;">The studio</a></li>
          <li><a href="#contact" style="color:rgba(255,255,255,0.55); text-decoration:none;">Begin</a></li>
          <li><a href="/accessibility" style="color:rgba(255,255,255,0.55); text-decoration:underline;">Accessibility</a></li>
        </ul>
      </div>
    </div>
    <div style="display:flex; justify-content:space-between; align-items:center; padding-top:1.25rem; gap:1rem; flex-wrap:wrap;">
      <p style="font-size:0.72rem; margin:0; color:rgba(255,255,255,0.3); font-style:italic;" class="garam">&copy; {new Date().getFullYear()} Meridian Design + Build &middot; CA Licensed C-27</p>
      <p style="font-size:0.7rem; margin:0; color:rgba(255,255,255,0.3);" class="garam">Built by <a href="https://dcrader.dev" style="color:rgba(200,169,106,0.7); text-decoration:underline;">Donovan Crader</a></p>
    </div>
  </div>
</footer>

</LandscapeLayout>
