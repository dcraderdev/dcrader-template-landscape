---
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { v2 as co } from '../data/company';
const fonts = "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap";

const heroBase = "/images/landscape/formal-estate";
const heroPreloadSrcset = `${heroBase}-640.avif 640w, ${heroBase}-1024.avif 1024w, ${heroBase}-1920.avif 1920w`;
const heroPreloadSizes = "100vw";

const projects = [
  { name: "Casa Cielo — Rancho Santa Fe", scope: "2.4-acre formal garden, reflecting pool, rose parterre, bespoke water feature", value: "$420,000", img: "/images/landscape/formal-estate.jpg", year: "2023" },
  { name: "Villa del Mar — La Jolla Shores", scope: "Blufftop infinity terrace, sculptural agave garden, specimen olive grove", value: "$285,000", img: "/images/landscape/coastal-blufftop.jpg", year: "2024" },
  { name: "The Whitmore Estate — Del Mar", scope: "French parterre, boxwood allées, croquet lawn, custom pergola dining", value: "$340,000", img: "/images/landscape/lawn-fresh-mowed.jpg", year: "2023" },
];

const testimonials = [
  { quote: "Meridian transformed our property into something we never thought possible. Every detail was considered, every plant chosen with intention.", name: "Catherine R.", location: "Rancho Santa Fe" },
  { quote: "The team understood our vision before we could articulate it. Working with them was effortless and the result is extraordinary.", name: "James & Priya W.", location: "La Jolla" },
];
---

<LandscapeLayout
  title="Meridian Design + Build — Luxury Landscape Studio, La Jolla"
  description="Meridian Design + Build creates singular estate gardens across La Jolla, Rancho Santa Fe, Del Mar, and Coronado. Bespoke design. Enduring legacy."
  fonts={fonts}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    fetchpriority="high"
    type="image/avif"
    imagesrcset={heroPreloadSrcset}
    imagesizes={heroPreloadSizes}
  />

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: #f9f7f2; color: #1e2b1e; margin: 0; }
  .garam { font-family: 'Cormorant Garamond', Georgia, serif; }

  /* color tokens */
  :root {
    --sage: #2e4a2e;
    --sage-mid: #3d5c3d;
    --champ: #c8a96a;
    --champ-light: #f0e8d0;
    --bg: #f9f7f2;
    --bg2: #f3ede1;
    --text: #1e2b1e;
    --muted: #7a7a6a;
    --rule: #d8cfa8;
  }

  .btn-inquire {
    display: inline-block;
    background: var(--champ, #c8a96a);
    color: #1e2b1e;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.18s;
    border: none;
    cursor: pointer;
  }
  .btn-inquire:hover { opacity: 0.85; }
  .btn-ghost {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.35);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: background 0.18s;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); }
  .rule { width: 48px; height: 1px; background: #c8a96a; }
  .label-sm {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c8a96a;
  }
  hr.divider { border: none; border-top: 1px solid #d8cfa8; margin: 0; }
</style>

<!-- NAV -->
<header style="background: rgba(30,42,30,0.97); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 50; border-bottom: 1px solid rgba(200,169,106,0.18);">
  <nav aria-label="Main navigation" style="max-width:88rem; margin:0 auto; padding:1.4rem 3rem; display:flex; align-items:center; justify-content:space-between;">
    <a href="#" style="text-decoration:none;">
      <span class="label-sm" style="color:#c8a96a; display:block; letter-spacing:0.25em;">Meridian</span>
      <span style="color:rgba(255,255,255,0.45); font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; display:block; margin-top:1px;">Design + Build · Est. {co.founded}</span>
    </a>
    <div style="display:flex; gap:2.5rem; align-items:center;">
      {['Services','Portfolio','Studio','Journal'].map(l => (
        <a href={`#${l.toLowerCase()}`} style="color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.82rem; letter-spacing:0.06em; font-weight:300; transition:color 0.18s;" onmouseover="this.style.color='rgba(255,255,255,0.95)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">{l}</a>
      ))}
      <a href="#contact" class="btn-inquire" style="padding:0.7rem 1.75rem;">Inquire</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO — full-height editorial -->
<section aria-label="Hero" style="position:relative; min-height:96vh; overflow:hidden; display:flex; align-items:flex-end;">
  <ResponsiveImage
    src="/images/landscape/formal-estate.jpg"
    alt="Luxury estate garden with formal pool and manicured hedges"
    width={1800} height={1200}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;"
  />
  <!-- gradient -->
  <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(10,18,10,0.9) 0%, rgba(10,18,10,0.3) 50%, rgba(10,18,10,0.1) 100%);"></div>
  <!-- content -->
  <div style="position:relative; z-index:1; max-width:88rem; margin:0 auto; padding:0 3rem 5rem; width:100%;">
    <div style="max-width:38rem;">
      <p class="label-sm" style="margin-bottom:1.25rem;">La Jolla, California</p>
      <h1 class="garam" style="color:#fff; font-size:clamp(3rem,6vw,5.5rem); font-weight:300; line-height:1.06; margin:0 0 1.5rem; letter-spacing:-0.01em;">
        Where landscape<br /><em>becomes legacy.</em>
      </h1>
      <div class="rule" style="margin-bottom:1.5rem;"></div>
      <p style="color:rgba(255,255,255,0.72); font-size:1rem; line-height:1.8; max-width:28rem; font-weight:300; margin-bottom:2rem;">
        A design-build studio creating estate gardens of singular beauty for discerning clients across coastal San Diego.
      </p>
      <div style="display:flex; gap:1.25rem; align-items:center;">
        <a href="#contact" class="btn-inquire">Begin Your Project</a>
        <a href="#portfolio" class="btn-ghost">View Portfolio</a>
      </div>
    </div>
  </div>
  <!-- scroll cue -->
  <div style="position:absolute; right:3rem; bottom:2.5rem; z-index:1; display:flex; flex-direction:column; align-items:center; gap:0.4rem;">
    <span style="color:rgba(255,255,255,0.4); font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; writing-mode:vertical-rl;">Scroll</span>
    <div style="width:1px; height:40px; background:rgba(200,169,106,0.5);"></div>
  </div>
</section>

<!-- MANIFESTO STRIP -->
<section style="background:#1e2b1e; padding:3.5rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:flex; gap:4rem; align-items:center; flex-wrap:wrap;">
    <p class="garam" style="color:#c8a96a; font-size:1.5rem; font-weight:300; font-style:italic; flex:1; min-width:240px; margin:0; line-height:1.5;">"A garden is the greatest reflection of the people who live within it."</p>
    <hr style="width:1px; height:80px; border:none; background:rgba(200,169,106,0.25);" aria-hidden="true" />
    <div style="flex:1; min-width:240px; display:flex; gap:3rem; flex-wrap:wrap;">
      {co.stats.map(s => (
        <div>
          <p class="garam" style="color:#fff; font-size:2.5rem; font-weight:600; margin:0; line-height:1;">{s.value}</p>
          <p style="color:rgba(255,255,255,0.45); font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; margin:0.4rem 0 0; font-weight:300;">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICES — numbered editorial list -->
<section id="services" aria-labelledby="svc-h" style="background:#f9f7f2; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:grid; grid-template-columns:280px 1fr; gap:6rem; align-items:start;">
    <div style="position:sticky; top:6rem;">
      <p class="label-sm" style="margin-bottom:1rem;">Studio expertise</p>
      <h2 id="svc-h" class="garam" style="font-size:3rem; font-weight:400; line-height:1.1; margin:0 0 1.5rem;">Our<br /><em>services</em></h2>
      <div class="rule"></div>
      <p style="color:#7a7a6a; margin-top:1.25rem; line-height:1.8; font-size:0.9rem; font-weight:300;">From first sketch to seasonal stewardship — we manage every detail of your outdoor legacy.</p>
    </div>
    <div>
      {co.services.map((s, i) => (
        <div>
          {i > 0 && <hr class="divider" />}
          <div style={`display:grid; grid-template-columns:60px 1fr; gap:2rem; align-items:start; padding:2.5rem 0;`}>
            <span class="garam" style="font-size:3.5rem; font-weight:300; color:#d8cfa8; line-height:1;">{String(i+1).padStart(2,'0')}</span>
            <div>
              <h3 style="font-size:1.2rem; font-weight:500; margin:0 0 0.6rem; color:#1e2b1e; letter-spacing:0.01em;">{s.title}</h3>
              <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; margin:0; font-weight:300;">{s.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PORTFOLIO — large editorial -->
<section id="portfolio" aria-labelledby="port-h" style="background:#f3ede1; padding:7rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:4rem; padding-bottom:1.5rem; border-bottom:1px solid #d8cfa8;">
      <div>
        <p class="label-sm">Selected work</p>
        <h2 id="port-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0 0;">Portfolio</h2>
      </div>
      <p style="color:#7a7a6a; font-size:0.82rem; font-weight:300;">2023 — 2024</p>
    </div>
    {projects.map((p, i) => (
      <div>
        {i > 0 && <hr class="divider" style="margin:0;" />}
        <div style={`display:grid; grid-template-columns:${i%2===0?'5fr 4fr':'4fr 5fr'}; gap:0; min-height:480px; ${i>0?'':'border-top:1px solid #d8cfa8;'}`}>
          <div style={`overflow:hidden; ${i%2===1?'order:1;':''}`}>
            <ResponsiveImage src={p.img} alt={p.name} width={900} height={600} sizes="(max-width: 1024px) 100vw, 50vw" loading="lazy" style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.6s ease;" />
          </div>
          <div style={`padding:3.5rem; display:flex; flex-direction:column; justify-content:center; background:${i%2===0?'#fff':'#f9f7f2'}; ${i%2===1?'order:0;':''}`}>
            <p class="label-sm" style="margin-bottom:1.25rem;">{p.year}</p>
            <h3 class="garam" style="font-size:2rem; font-weight:400; margin:0 0 1.25rem; line-height:1.2;">{p.name}</h3>
            <div class="rule" style="margin-bottom:1.25rem;"></div>
            <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; font-weight:300; margin-bottom:1.75rem;">{p.scope}</p>
            <p style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#c8a96a; font-weight:500;">Project investment: {p.value}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- BEFORE/AFTER -->
<section aria-labelledby="ba-h" style="background:#f9f7f2; padding:6rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="text-align:center; margin-bottom:4rem;">
      <p class="label-sm">Transformations</p>
      <h2 id="ba-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0;">Before &amp; after</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(380px,1fr)); gap:2.5rem;">
      {co.beforeAfter.map(ba => (
        <div>
          <h3 class="garam" style="font-size:1.25rem; font-weight:400; margin-bottom:1.25rem; font-style:italic;">{ba.label}</h3>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.5rem;">
            <div>
              <p class="label-sm" style="margin-bottom:0.5rem; color:#7a7a6a;">Before</p>
              <ResponsiveImage src={ba.before} alt={`Before: ${ba.label}`} width={400} height={280} sizes="(max-width: 768px) 50vw, 200px" loading="lazy" style="width:100%; height:200px; object-fit:cover; display:block;" />
            </div>
            <div>
              <p class="label-sm" style="margin-bottom:0.5rem;">After</p>
              <ResponsiveImage src={ba.after} alt={`After: ${ba.label}`} width={400} height={280} sizes="(max-width: 768px) 50vw, 200px" loading="lazy" style="width:100%; height:200px; object-fit:cover; display:block;" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section style="background:#1e2b1e; padding:6rem 3rem;">
  <div style="max-width:72rem; margin:0 auto;">
    <p class="label-sm" style="text-align:center; display:block; margin-bottom:3rem;">Client words</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(340px,1fr)); gap:3rem;">
      {testimonials.map(t => (
        <div style="border-top:1px solid rgba(200,169,106,0.3); padding-top:2rem;">
          <p class="garam" style="color:rgba(255,255,255,0.88); font-size:1.2rem; font-style:italic; line-height:1.75; margin:0 0 1.5rem; font-weight:300;">"{t.quote}"</p>
          <div class="rule"></div>
          <p style="color:#c8a96a; font-size:0.82rem; margin:1rem 0 0; font-weight:500;">{t.name} <span style="color:rgba(255,255,255,0.35); font-weight:300;">— {t.location}</span></p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CERTIFICATIONS -->
<section aria-labelledby="certs-h" style="background:#f3ede1; padding:5rem 3rem;">
  <div style="max-width:88rem; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:3rem; align-items:center;">
    <div>
      <p class="label-sm" style="margin-bottom:0.75rem;">Credentials</p>
      <h2 id="certs-h" class="garam" style="font-size:2.5rem; font-weight:400; margin:0 0 1.25rem;">Certified excellence</h2>
      <p style="color:#7a7a6a; font-size:0.9rem; line-height:1.8; font-weight:300;">Every project is led by licensed designers with deep expertise in horticulture, construction, and estate stewardship.</p>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
      {co.certifications.map(c => (
        <span style="border:1px solid #c8a96a; color:#1e2b1e; font-size:0.82rem; font-weight:500; padding:0.55rem 1.25rem; letter-spacing:0.03em;">{c}</span>
      ))}
    </div>
  </div>
</section>

<!-- TEAM -->
<section id="studio" aria-labelledby="team-h" style="background:#f9f7f2; padding:6rem 3rem;">
  <div style="max-width:88rem; margin:0 auto;">
    <div style="text-align:center; margin-bottom:4rem;">
      <p class="label-sm">The people</p>
      <h2 id="team-h" class="garam" style="font-size:3rem; font-weight:400; margin:0.5rem 0;">The Studio</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:2rem;">
      {co.teamMembers.map(m => (
        <div style="text-align:center;">
          <div style="width:88px; height:88px; border-radius:50%; background:#2e4a2e; margin:0 auto 1.25rem; display:flex; align-items:center; justify-content:center; border:1px solid #c8a96a;" aria-hidden="true">
            <span class="garam" style="color:#c8a96a; font-size:2.25rem; font-weight:600; line-height:1;">{m.name[0]}</span>
          </div>
          <h3 class="garam" style="font-size:1.2rem; font-weight:400; margin:0 0 0.25rem;">{m.name}</h3>
          <p style="color:#7a7a6a; font-size:0.82rem; font-weight:300; margin:0;">{m.role}</p>
          {m.cert && <p style="color:#c8a96a; font-size:0.75rem; font-weight:500; margin:0.35rem 0 0; letter-spacing:0.04em;">{m.cert}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT — no pricing, just inquiry -->
<section id="contact" aria-labelledby="contact-h" style="background:#f3ede1; padding:7rem 3rem;">
  <div style="max-width:52rem; margin:0 auto;">
    <div style="text-align:center; margin-bottom:4rem;">
      <p class="label-sm">Begin</p>
      <h2 id="contact-h" class="garam" style="font-size:3.5rem; font-weight:300; margin:0.5rem 0 1rem; line-height:1.1;">Start the<br /><em>conversation</em></h2>
      <div class="rule" style="margin:1.5rem auto;"></div>
      <p style="color:#7a7a6a; font-size:0.95rem; line-height:1.8; font-weight:300;">We accept a limited number of new projects each season. We would love to hear about yours.</p>
    </div>
    <form novalidate aria-label="Project inquiry form" style="display:grid; gap:1.1rem;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.1rem;">
        <div>
          <label for="v2-fn" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">First name</label>
          <input id="v2-fn" name="first_name" type="text" required autocomplete="given-name" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; outline:none;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
        </div>
        <div>
          <label for="v2-ln" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Last name</label>
          <input id="v2-ln" name="last_name" type="text" required autocomplete="family-name" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; outline:none;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
        </div>
      </div>
      <div>
        <label for="v2-email" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Email address</label>
        <input id="v2-email" name="email" type="email" required autocomplete="email" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; outline:none;" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
      </div>
      <div>
        <label for="v2-loc" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Property location</label>
        <input id="v2-loc" name="location" type="text" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; outline:none;" placeholder="City or neighborhood" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'" />
      </div>
      <div>
        <label for="v2-scope" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Project scope</label>
        <select id="v2-scope" name="scope" style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; outline:none; appearance:auto;">
          <option value="">Please select…</option>
          {co.services.map(s => <option value={s.title}>{s.title}</option>)}
        </select>
      </div>
      <div>
        <label for="v2-vision" style="font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:#7a7a6a; display:block; margin-bottom:0.5rem;">Your vision</label>
        <textarea id="v2-vision" name="vision" rows={5} style="width:100%; padding:0.875rem; border:1px solid #d8cfa8; border-radius:0; background:#fff; font-size:0.95rem; font-family:'DM Sans',sans-serif; color:#1e2b1e; resize:vertical; outline:none;" placeholder="Tell us about your property, your aspirations, and what you hope to create…" onfocus="this.style.borderColor='#c8a96a'" onblur="this.style.borderColor='#d8cfa8'"></textarea>
      </div>
      <button type="submit" class="btn-inquire" style="width:100%; padding:1.1rem; font-size:0.85rem;">Submit Inquiry</button>
    </form>
    <p style="text-align:center; color:#7a7a6a; font-size:0.78rem; margin-top:1.5rem; font-weight:300;">{co.phone} · {co.email}</p>
  </div>
</section>

</main>

<footer style="background:#111a11; color:rgba(255,255,255,0.4); padding:3rem; text-align:center;">
  <div style="max-width:88rem; margin:0 auto;">
    <p class="garam" style="color:#c8a96a; font-size:1.1rem; font-weight:400; margin-bottom:0.5rem;">Meridian Design + Build</p>
    <p style="font-size:0.78rem; margin-bottom:0.4rem;">{co.address}</p>
    <p style="font-size:0.72rem;">&copy; {new Date().getFullYear()} Meridian Design + Build. All rights reserved. CA Licensed.</p>
  </div>
