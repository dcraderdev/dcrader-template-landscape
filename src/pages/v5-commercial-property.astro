---
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import QuoteFormHero from '../components/landscape/QuoteFormHero.astro';
import { v5 as co } from '../data/company';
const fonts = "https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,700;0,900;1,400&display=swap";

const trustSignals = [
  { label: "$5M General Liability", icon: "🛡️" },
  { label: "Workers' Comp Insured", icon: "✅" },
  { label: "DIR Registered Contractor", icon: "📋" },
  { label: "OSHA 10 Certified Crews", icon: "⛑️" },
  { label: "ISO 9001 Quality System", icon: "🏆" },
  { label: "NALP Accredited Company", icon: "🎖️" },
];

const contractTiers = [
  {
    name: "Standard",
    price: "$495",
    period: "/mo per acre",
    sla: "48-hr response",
    features: ["Weekly grounds maintenance","Weed & pest control","Monthly inspection report","Dedicated account manager","Email + phone support"],
    highlight: false,
  },
  {
    name: "Professional",
    price: "$895",
    period: "/mo per acre",
    sla: "24-hr response",
    features: ["Weekly maintenance","Smart irrigation monitoring","Seasonal color rotations","Hardscape upkeep & pressure washing","QA inspection + photo report","Priority scheduling"],
    highlight: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    sla: "4-hr emergency SLA",
    features: ["Multi-site unified management","Custom SLA agreement","24/7 operations line","Dedicated crew assignment","Quarterly business reviews","Sustainability ESG reporting"],
    highlight: false,
  },
];
---

<LandscapeLayout
  title="Apex Commercial Landscapes — Commercial Maintenance Contracts, San Diego"
  description="Apex Commercial Landscapes manages office parks, retail centers, HOAs, and hospitality properties across greater San Diego. NALP accredited, ISO 9001 certified."
  fonts={fonts}
>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'Archivo', sans-serif; background: #fff; color: #0d1b3e; margin: 0; }

  :root {
    --navy: #0d1b3e;
    --navy-mid: #1a2d5a;
    --navy-light: #2a3f70;
    --silver: #8394b0;
    --silver-light: #c8d4e8;
    --bg: #ffffff;
    --bg2: #f4f7fb;
    --text: #0d1b3e;
    --muted: #6a7a90;
    --border: #c0ccd8;
  }

  .btn-navy {
    display: inline-block;
    background: #0d1b3e;
    color: #fff;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: background 0.18s;
    border: none;
    cursor: pointer;
  }
  .btn-navy:hover { background: #0a1530; }
  .btn-outline-navy {
    display: inline-block;
    background: transparent;
    color: #0d1b3e;
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.875rem 2rem;
    border: 2px solid #0d1b3e;
    text-decoration: none;
    transition: all 0.18s;
  }
  .btn-outline-navy:hover { background: #0d1b3e; color: #fff; }
  .btn-white {
    display: inline-block;
    background: #fff;
    color: #0d1b3e;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.9rem 2rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.18s;
  }
  .btn-white:hover { opacity: 0.92; }
  .label { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #8394b0; margin-bottom: 0.6rem; }
  .card { background: #f4f7fb; border: 1px solid #c0ccd8; padding: 1.75rem; }
  section { padding: 5rem 2rem; }
  .inner { max-width: 80rem; margin: 0 auto; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 0.875rem 1rem; border-bottom: 1px solid #c0ccd8; font-size: 0.88rem; }
  th { background: #0d1b3e; color: #fff; font-weight: 700; letter-spacing: 0.04em; font-size: 0.78rem; text-transform: uppercase; }
  tr:hover td { background: #f4f7fb; }
</style>

<!-- TRUST BAR -->
<div style="background:#0d1b3e; padding:0.6rem 2rem; overflow-x:auto;">
  <div style="max-width:80rem; margin:0 auto; display:flex; gap:2.5rem; align-items:center; white-space:nowrap;">
    {trustSignals.map(t => (
      <span style="color:rgba(255,255,255,0.65); font-size:0.75rem; display:flex; align-items:center; gap:0.4rem; flex-shrink:0;">
        <span aria-hidden="true">{t.icon}</span> {t.label}
      </span>
    ))}
  </div>
</div>

<!-- NAV -->
<header style="background:#fff; border-bottom:1px solid #c0ccd8; position:sticky; top:0; z-index:50;">
  <nav aria-label="Main navigation" style="max-width:80rem; margin:0 auto; padding:1rem 2rem; display:flex; align-items:center; justify-content:space-between;">
    <a href="#" style="text-decoration:none; display:flex; align-items:center; gap:0.75rem;">
      <div style="width:36px; height:36px; background:#0d1b3e; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="10" width="16" height="8" rx="1" stroke="#8394b0" stroke-width="1.5"/><rect x="5" y="4" width="10" height="8" rx="1" stroke="#c8d4e8" stroke-width="1.5"/><rect x="8" y="1" width="4" height="5" rx="1" stroke="#fff" stroke-width="1.5"/></svg>
      </div>
      <div>
        <span style="font-weight:900; font-size:1.05rem; color:#0d1b3e; display:block; line-height:1.1; letter-spacing:-0.01em;">APEX</span>
        <span style="color:#4a5a72; font-size:0.58rem; letter-spacing:0.18em; text-transform:uppercase; display:block;">Commercial Landscapes</span>
      </div>
    </a>
    <div style="display:flex; gap:2rem; align-items:center;">
      <a href="#services" style="color:#4a5a72; text-decoration:none; font-size:0.85rem; font-weight:500;">Services</a>
      <a href="/v5-commercial-grounds-management" style="color:#4a5a72; text-decoration:none; font-size:0.85rem; font-weight:500;">Grounds Mgmt</a>
      <a href="#contracts" style="color:#4a5a72; text-decoration:none; font-size:0.85rem; font-weight:500;">Contracts</a>
      <a href="#portfolio" style="color:#4a5a72; text-decoration:none; font-size:0.85rem; font-weight:500;">Portfolio</a>
      <a href="#contact" class="btn-navy" style="padding:0.6rem 1.5rem; font-size:0.85rem;">Request Proposal</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO — instant RFQ form (variant 5) -->
<QuoteFormHero
  brand={co.name}
  eyebrow="Instant property quote · since 1998"
  headline="Professional Property."
  headlineEm="Premium Presentation."
  body="Commercial landscape management for office campuses, retail centers, HOAs, and hospitality properties across greater San Diego. Submit your site details — we'll return a written proposal within one business day."
  phone={co.phone}
/>

<!-- PROPERTY TYPES STRIP -->
<section style="background:#f4f7fb; padding:2.5rem 2rem;">
  <div class="inner" style="display:flex; gap:0; flex-wrap:wrap; justify-content:space-between; align-items:center;">
    {[
      { icon: '🏢', label: 'Office Parks' },
      { icon: '🛍️', label: 'Retail Centers' },
      { icon: '🏨', label: 'Hospitality' },
      { icon: '🏘️', label: 'HOA Communities' },
      { icon: '🏗️', label: 'Industrial' },
      { icon: '🏛️', label: 'Municipal' },
    ].map(p => (
      <div style="text-align:center; padding:0.75rem 1.5rem; flex:1; min-width:120px;">
        <span style="font-size:2rem; display:block;" aria-hidden="true">{p.icon}</span>
        <span style="font-size:0.75rem; font-weight:700; color:#4a5a72; text-transform:uppercase; letter-spacing:0.1em;">{p.label}</span>
      </div>
    ))}
  </div>
</section>

<!-- SERVICES -->
<section id="services" aria-labelledby="svc-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:280px 1fr; gap:5rem; align-items:start;">
      <div>
        <span class="label">What we provide</span>
        <h2 id="svc-h" style="font-size:2.25rem; font-weight:900; margin:0.25rem 0 1.25rem; letter-spacing:-0.02em;">Commercial services</h2>
        <p style="color:#4a5a72; line-height:1.75; font-size:0.9rem; margin-bottom:1.5rem;">Scalable programs with dedicated account managers, monthly reporting, and performance SLAs.</p>
        <a href="#contact" class="btn-navy">Get a Proposal</a>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1px; background:#c0ccd8; border:1px solid #c0ccd8;">
        {co.services.map((s, i) => (
          <div style={`background:${i%2===0?'#fff':'#f4f7fb'}; padding:1.5rem;`}>
            <span style="font-size:1.75rem; display:block; margin-bottom:0.75rem;" aria-hidden="true">{s.icon}</span>
            <h3 style="font-size:0.95rem; font-weight:700; margin:0 0 0.4rem; color:#0d1b3e;">{s.title}</h3>
            <p style="color:#4a5a72; font-size:0.85rem; line-height:1.65; margin:0;">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- SNOW & ICE FEATURE -->
<section style="background:#0d1b3e; padding:5rem 2rem;">
  <div class="inner" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:3rem; align-items:center;">
    <div>
      <span class="label" style="color:#8394b0;">Seasonal specialty</span>
      <h2 style="color:#fff; font-size:2.25rem; font-weight:900; margin:0.25rem 0 1rem; letter-spacing:-0.02em;">Snow &amp; ice<br />management</h2>
      <p style="color:rgba(255,255,255,0.6); line-height:1.8; font-size:0.95rem; margin-bottom:1.5rem;">For Northern California commercial clients, we provide pre-treatment, de-icing, salting, and snow removal with 4-hour response SLAs. Keep your property open and your tenants safe.</p>
      <ul style="list-style:none; padding:0; margin:0 0 2rem; display:flex; flex-direction:column; gap:0.6rem;">
        {['Pre-storm salt application', 'Anti-icing liquid pre-treatment', 'Snow plowing & hauling', 'Walkway hand-clearing', 'Post-storm inspection', '4-hr response SLA guarantee'].map(f => (
          <li style="display:flex; gap:0.6rem; font-size:0.9rem; color:rgba(255,255,255,0.8); align-items:flex-start;">
            <span style="color:#8394b0; flex-shrink:0;" aria-hidden="true">❄️</span> {f}
          </li>
        ))}
      </ul>
      <a href="#contact" class="btn-white">Add to your contract</a>
    </div>
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); padding:2.5rem; text-align:center;">
      <span style="font-size:5rem; display:block; margin-bottom:1rem;" aria-hidden="true">❄️</span>
      <p style="color:rgba(255,255,255,0.5); font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; margin:0 0 1.5rem;">Available for</p>
      {['Sacramento Valley','Central Valley','Inland Empire','Tahoe-area properties'].map(loc => (
        <p style="color:#fff; font-size:0.9rem; margin:0 0 0.5rem; font-weight:500;">{loc}</p>
      ))}
    </div>
  </div>
</section>

<!-- CONTRACT TIERS -->
<section id="contracts" aria-labelledby="contracts-h" style="background:#f4f7fb; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3.5rem;">
      <span class="label">Maintenance contracts</span>
      <h2 id="contracts-h" style="font-size:2.5rem; font-weight:900; margin:0.25rem 0 0.75rem; letter-spacing:-0.02em;">Landscape maintenance programs</h2>
      <p style="color:#4a5a72; max-width:36rem; margin:0 auto; line-height:1.75; font-size:0.92rem;">All contracts include a dedicated account manager, monthly QA inspection, and photo report. SLA guarantees are in writing.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; align-items:start;">
      {contractTiers.map(t => (
        <div style={`background:${t.highlight?'#0d1b3e':'#fff'}; border:${t.highlight?'2px solid #0d1b3e':'1px solid #c0ccd8'}; padding:2rem; ${t.highlight?'transform:translateY(-6px);':''}`}>
          {t.highlight && <p style="font-size:0.68rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#8394b0; margin:0 0 0.75rem;">Most Popular</p>}
          <h3 style={`font-size:1.3rem; font-weight:900; margin:0 0 0.25rem; letter-spacing:-0.01em; ${t.highlight?'color:#fff;':''}`}>{t.name}</h3>
          <p style={`font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1rem; ${t.highlight?'color:#8394b0;':'color:#8394b0;'}`}>SLA: {t.sla}</p>
          <div style="display:flex; align-items:baseline; gap:0.25rem; margin-bottom:1.5rem;">
            <span style={`font-size:2.75rem; font-weight:900; letter-spacing:-0.02em; ${t.highlight?'color:#fff;':'color:#0d1b3e;'}`}>{t.price}</span>
            <span style={`font-size:0.85rem; ${t.highlight?'color:rgba(255,255,255,0.5);':'color:#4a5a72;'}`}>{t.period}</span>
          </div>
          <ul style="list-style:none; padding:0; margin:0 0 1.75rem; display:flex; flex-direction:column; gap:0.65rem;">
            {t.features.map(f => (
              <li style="display:flex; gap:0.6rem; font-size:0.875rem; align-items:flex-start; line-height:1.5;">
                <span style={`flex-shrink:0; font-weight:700; ${t.highlight?'color:#8394b0;':'color:#0d1b3e;'}`} aria-hidden="true">✓</span>
                <span style={t.highlight?'color:rgba(255,255,255,0.85);':''}>{f}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class="btn-navy" style={`display:block; text-align:center; ${t.highlight?'background:#fff; color:#0d1b3e;':''}`}>Request Proposal</a>
        </div>
      ))}
    </div>
    <!-- SLA table -->
    <div style="margin-top:2.5rem; overflow-x:auto;">
      <table>
        <caption style="text-align:left; font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#4a5a72; padding-bottom:0.75rem;">Service Level Comparison</caption>
        <thead>
          <tr>
            <th>Feature</th>
            <th>Standard</th>
            <th>Professional</th>
            <th>Enterprise</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Response SLA', '48 hours', '24 hours', '4 hours'],
            ['Account Manager', '✓', '✓', 'Dedicated senior'],
            ['Reporting', 'Monthly', 'Monthly + photos', 'Custom dashboard'],
            ['Multi-site support', '—', '—', '✓'],
            ['Emergency line', '—', '✓', '24/7 direct'],
            ['Sustainability report', '—', '—', 'Quarterly ESG'],
          ].map(row => (
            <tr>
              {row.map((cell, ci) => (
                ci === 0
                  ? <td style="font-weight:600; color:#0d1b3e;">{cell}</td>
                  : <td style="color:#4a5a72;">{cell}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- PORTFOLIO -->
<section id="portfolio" aria-labelledby="port-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">Client showcase</span>
      <h2 id="port-h" style="font-size:2.25rem; font-weight:900; margin:0.25rem 0; letter-spacing:-0.02em;">Selected accounts</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:1.5rem;">
      {co.portfolio.map(p => (
        <figure style="margin:0; border:1px solid #c0ccd8;">
          <ResponsiveImage src={p.img} alt={p.title} width={600} height={400} sizes="(max-width: 768px) 100vw, 33vw" loading="lazy" style="width:100%; height:240px; object-fit:cover; display:block;" />
          <figcaption style="padding:1.5rem; background:#f4f7fb;">
            <h3 style="font-weight:700; font-size:1rem; margin:0 0 0.35rem; color:#0d1b3e;">{p.title}</h3>
            <p style="color:#4a5a72; font-size:0.875rem; margin:0; line-height:1.6;">{p.description}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- ACCOUNT KPIs — pure metric-shift cards (no B/A image grid) -->
<section aria-labelledby="ba-h" style="background:#f4f7fb; padding:5rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:3rem; align-items:end; margin-bottom:3rem; padding-bottom:1.25rem; border-bottom:2px solid #0d1b3e;">
      <div>
        <span class="label">Account performance</span>
        <h2 id="ba-h" style="font-size:2.25rem; font-weight:900; margin:0.4rem 0 0; letter-spacing:-0.02em;">What changes after takeover</h2>
      </div>
      <p style="color:#4a5a72; font-size:0.9rem; line-height:1.75; margin:0;">Three live accounts, first twelve months. Numbers pulled directly from QA reports and tenant ticket logs.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.25rem;">
      {[
        {
          site:'Mission Valley Office Park',
          type:'12-acre mixed-use · 4 buildings',
          metrics:[
            { label:'Water budget vs. baseline', before:'+18% over', after:'−24% under', good:true },
            { label:'Tenant complaint tickets / mo', before:'14', after:'2', good:true },
            { label:'Curb-appeal QA score', before:'62', after:'94', good:true },
            { label:'Avg response time', before:'5.2 days', after:'18 hrs', good:true },
          ],
        },
        {
          site:'Kearny Mesa Retail Center',
          type:'400-stall retail · 8 anchors',
          metrics:[
            { label:'Parking-lot weed coverage', before:'~22%', after:'<2%', good:true },
            { label:'Seasonal color rotations / yr', before:'1', after:'4', good:true },
            { label:'Anchor-tenant renewals', before:'5 of 8', after:'8 of 8', good:true },
            { label:'Annual irrigation cost', before:'$48K', after:'$31K', good:true },
          ],
        },
        {
          site:'Downtown Hilton San Diego',
          type:'448 keys · event lawn + entry',
          metrics:[
            { label:'Event-lawn ready days / yr', before:'214', after:'358', good:true },
            { label:'Guest landscape comments', before:'mixed', after:'92% positive', good:true },
            { label:'Crew on-site at event setup', before:'On call', after:'Pre-scheduled', good:true },
            { label:'AAA inspection score', before:'4 diamond', after:'5 diamond', good:true },
          ],
        },
      ].map(account => (
        <article style="background:#fff; border:1px solid #c0ccd8; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
          <header style="border-bottom:1px solid #c0ccd8; padding-bottom:0.85rem;">
            <h3 style="font-size:1rem; font-weight:700; margin:0; color:#0d1b3e;">{account.site}</h3>
            <p style="font-size:0.74rem; color:#8394b0; margin:0.25rem 0 0; letter-spacing:0.06em; text-transform:uppercase;">{account.type}</p>
          </header>
          <table style="width:100%; border-collapse:collapse;">
            <thead>
              <tr>
                <th style="background:transparent; color:#8394b0; font-weight:700; font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; text-align:left; padding:0 0 0.4rem; border-bottom:1px solid #e0e5ec;">KPI</th>
                <th style="background:transparent; color:#8394b0; font-weight:700; font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; text-align:right; padding:0 0 0.4rem; border-bottom:1px solid #e0e5ec;">Pre</th>
                <th style="background:transparent; color:#0d1b3e; font-weight:900; font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; text-align:right; padding:0 0 0.4rem; border-bottom:1px solid #e0e5ec;">w/ Apex</th>
              </tr>
            </thead>
            <tbody>
              {account.metrics.map(m => (
                <tr>
                  <td style="font-size:0.78rem; color:#0d1b3e; padding:0.5rem 0; border-bottom:1px dashed #e0e5ec;">{m.label}</td>
                  <td style="font-size:0.78rem; color:#4a5a72; padding:0.5rem 0; border-bottom:1px dashed #e0e5ec; text-align:right; font-family:monospace;">{m.before}</td>
                  <td style="font-size:0.78rem; color:#0d1b3e; font-weight:900; padding:0.5rem 0; border-bottom:1px dashed #e0e5ec; text-align:right; font-family:monospace;">{m.after}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p style="margin:auto 0 0; padding-top:0.5rem; font-size:0.7rem; color:#8394b0; letter-spacing:0.08em; text-transform:uppercase; font-weight:700;">Year-over-year &middot; QA verified</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- PROPERTY-MANAGER VOICES — logo strip + 2 quotes -->
<section aria-labelledby="pm-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <span class="label">Property managers on record</span>
      <h2 id="pm-h" style="font-size:2rem; font-weight:900; margin:0.25rem 0; letter-spacing:-0.02em;">Trusted by the people who run buildings</h2>
    </div>
    <!-- Logo-style monogram strip -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:0; border-top:1px solid #c0ccd8; border-bottom:1px solid #c0ccd8; margin-bottom:3rem;">
      {[
        { mono:'CBRE', sub:'PM, San Diego' },
        { mono:'JLL', sub:'Office portfolios' },
        { mono:'KILROY', sub:'Mixed-use' },
        { mono:'IRVINE', sub:'Campus PM' },
        { mono:'HINES', sub:'Class-A retail' },
        { mono:'GREYSTAR', sub:'Multifamily' },
      ].map((l, i) => (
        <div style={`padding:1.25rem 0.75rem; text-align:center; ${i<5?'border-right:1px solid #c0ccd8;':''} display:flex; flex-direction:column; gap:0.15rem; justify-content:center;`}>
          <span style="font-size:0.95rem; font-weight:900; color:#0d1b3e; letter-spacing:0.04em;">{l.mono}</span>
          <span style="font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; color:#8394b0;">{l.sub}</span>
        </div>
      ))}
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:1.5rem;">
      {[
        { quote:'Apex took over a 12-acre office park mid-contract from a competitor and stabilized it in six weeks. The QA reports replaced three different vendor reports I used to chase. One inbox, one number.', name:'Patricia Vega', title:'Senior Property Manager', firm:'CBRE · Mission Valley portfolio' },
        { quote:'Snow event in 2024, they had crews pre-positioned. Our tenants opened on time when three other centers in the corridor didn’t. The SLA is in writing and they’ve never missed it.', name:'Derek Chu', title:'Director of Operations', firm:'JLL · Greater San Diego' },
      ].map(t => (
        <article style="background:#f4f7fb; border-left:4px solid #0d1b3e; padding:1.75rem 1.75rem 1.5rem;">
          <p style="font-size:0.95rem; line-height:1.7; color:#0d1b3e; margin:0 0 1.25rem;">&ldquo;{t.quote}&rdquo;</p>
          <p style="margin:0; padding-top:1rem; border-top:1px solid #c0ccd8;">
            <span style="display:block; font-weight:900; font-size:0.85rem; color:#0d1b3e; letter-spacing:-0.01em;">{t.name}</span>
            <span style="display:block; font-size:0.75rem; color:#8394b0; letter-spacing:0.08em; text-transform:uppercase; margin-top:0.15rem;">{t.title}</span>
            <span style="display:block; font-size:0.78rem; color:#4a5a72; margin-top:0.2rem;">{t.firm}</span>
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- LEADERSHIP — org-chart roster, no avatars -->
<section aria-labelledby="team-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:3rem; align-items:start; margin-bottom:2.5rem;">
      <div>
        <span class="label">Leadership</span>
        <h2 id="team-h" style="font-size:2rem; font-weight:900; margin:0.4rem 0 0.75rem; letter-spacing:-0.02em;">Your accountable team</h2>
        <p style="color:#4a5a72; font-size:0.9rem; line-height:1.75; margin:0;">Every commercial account is assigned a named Account Executive, an Operations lead, and a QA contact. No call-center handoffs.</p>
      </div>
      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid #0d1b3e;">
            <th style="background:transparent; color:#0d1b3e; font-weight:900; font-size:0.66rem; letter-spacing:0.18em; text-transform:uppercase; padding:0 0 0.6rem; text-align:left;">Role</th>
            <th style="background:transparent; color:#0d1b3e; font-weight:900; font-size:0.66rem; letter-spacing:0.18em; text-transform:uppercase; padding:0 0 0.6rem; text-align:left;">Name</th>
            <th style="background:transparent; color:#0d1b3e; font-weight:900; font-size:0.66rem; letter-spacing:0.18em; text-transform:uppercase; padding:0 0 0.6rem; text-align:right;">Direct</th>
          </tr>
        </thead>
        <tbody>
          {co.teamMembers.map((m, i) => {
            const ext = ['x101','x204','x115','x132'];
            return (
              <tr>
                <td style="font-size:0.78rem; color:#4a5a72; padding:0.85rem 0; border-bottom:1px solid #c0ccd8; letter-spacing:0.04em;">{m.role}</td>
                <td style="font-size:0.88rem; color:#0d1b3e; font-weight:700; padding:0.85rem 0; border-bottom:1px solid #c0ccd8;">{m.name}</td>
                <td style="font-size:0.78rem; color:#0d1b3e; padding:0.85rem 0; border-bottom:1px solid #c0ccd8; font-family:monospace; text-align:right;">{co.phone} <span style="color:#8394b0;">{ext[i] || ''}</span></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- B2B TRUST SIGNALS -->
<section aria-labelledby="trust-h" style="background:#f4f7fb; padding:4rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2.5rem; align-items:center;">
      <div>
        <span class="label">Standards &amp; compliance</span>
        <h2 id="trust-h" style="font-size:2rem; font-weight:900; margin:0.25rem 0 1rem; letter-spacing:-0.02em;">Why property managers choose Apex</h2>
        <p style="color:#4a5a72; line-height:1.75; font-size:0.9rem;">Every contract includes written SLAs, $5M liability coverage, OSHA-compliant crews, and DIR-registered labor. We carry the risk — so you don't have to.</p>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        {trustSignals.map(t => (
          <div style="background:#fff; border:1px solid #c0ccd8; padding:1rem; display:flex; align-items:center; gap:0.75rem;">
            <span style="font-size:1.5rem;" aria-hidden="true">{t.icon}</span>
            <span style="font-size:0.82rem; font-weight:600; color:#0d1b3e; line-height:1.35;">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CONTACT — RFP FORM -->
<section id="contact" aria-labelledby="contact-h" style="background:#0a1020; padding:5rem 2rem;">
  <div style="max-width:50rem; margin:0 auto; text-align:center;">
    <span class="label" style="color:#8394b0;">Start a proposal</span>
    <h2 id="contact-h" style="color:#fff; font-size:2.5rem; font-weight:900; margin:0.35rem 0 0.75rem; letter-spacing:-0.02em;">Request a landscape proposal</h2>
    <p style="color:rgba(255,255,255,0.55); margin-bottom:2.5rem; line-height:1.75; font-size:0.92rem;">We conduct a property walk, assess your current landscape, and deliver a custom maintenance proposal within 3 business days.</p>
    <form novalidate aria-label="Commercial landscape proposal request" style="display:grid; gap:1rem; text-align:left;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div>
          <label for="v5-fn" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">First name <span aria-hidden="true">*</span></label>
          <input id="v5-fn" name="first_name" type="text" required autocomplete="given-name" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
        </div>
        <div>
          <label for="v5-ln" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Last name <span aria-hidden="true">*</span></label>
          <input id="v5-ln" name="last_name" type="text" required autocomplete="family-name" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
        </div>
      </div>
      <div>
        <label for="v5-co" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Company / Property name <span aria-hidden="true">*</span></label>
        <input id="v5-co" name="company" type="text" required autocomplete="organization" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" placeholder="Acme Properties LLC" />
      </div>
      <div>
        <label for="v5-email" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Email <span aria-hidden="true">*</span></label>
        <input id="v5-email" name="email" type="email" required autocomplete="email" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div>
          <label for="v5-type" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Property type</label>
          <select id="v5-type" name="property_type" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(10,16,32,0.98); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;">
            <option value="">Select…</option>
            <option>Office Campus / Park</option>
            <option>Retail Center</option>
            <option>Hotel / Hospitality</option>
            <option>HOA / Multi-Family</option>
            <option>Industrial / Flex</option>
            <option>Municipal / Government</option>
          </select>
        </div>
        <div>
          <label for="v5-tier" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Contract tier interest</label>
          <select id="v5-tier" name="tier" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(10,16,32,0.98); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;">
            <option value="">Not sure</option>
            {contractTiers.map(t => <option value={t.name}>{t.name}</option>)}
          </select>
        </div>
      </div>
      <div>
        <label for="v5-details" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Property details</label>
        <textarea id="v5-details" name="details" rows={4} style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif; resize:vertical;" placeholder="Square footage, number of sites, current provider, key pain points…"></textarea>
      </div>
      <button type="submit" class="btn-white" style="width:100%; padding:1.1rem; font-size:0.95rem; font-weight:700;">Submit for Proposal →</button>
    </form>
    <p style="color:rgba(255,255,255,0.3); font-size:0.78rem; margin-top:1.5rem;">{co.phone} · {co.email} · proposals delivered within 3 business days</p>
  </div>
</section>

</main>

<!-- FOOTER — corporate compliance grid with sitemap and SLA strip -->
<footer style="background:#050d1a; color:rgba(255,255,255,0.5); padding:0 0 1.5rem;">
  <!-- Operations SLA bar -->
  <div style="background:#0d1b3e; padding:1rem 2rem; border-top:1px solid rgba(131,148,176,0.18);">
    <div style="max-width:80rem; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:1.5rem; flex-wrap:wrap;">
      <div style="display:flex; align-items:center; gap:0.85rem;">
        <span aria-hidden="true" style="display:inline-block; width:10px; height:10px; border-radius:50%; background:#3fb950; box-shadow:0 0 8px rgba(63,185,80,0.6);"></span>
        <span style="font-size:0.78rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.85);">Operations · Open</span>
        <span style="font-size:0.74rem; color:rgba(255,255,255,0.5);">Mon – Fri · 06:00 – 18:00 PT</span>
      </div>
      <div style="display:flex; gap:1.25rem; font-size:0.74rem; color:rgba(255,255,255,0.55); letter-spacing:0.04em;">
        <span>Account line: <a href={`tel:${co.phone.replace(/\D/g,'')}`} style="color:#fff; font-family:monospace; text-decoration:none;">{co.phone}</a></span>
        <span>RFP: <a href={`mailto:${co.email}`} style="color:#fff; text-decoration:none;">{co.email}</a></span>
      </div>
    </div>
  </div>
  <div style="max-width:80rem; margin:0 auto; padding:3rem 2rem 0;">
    <div style="display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:2rem; padding-bottom:2rem; border-bottom:1px solid rgba(131,148,176,0.15);">
      <div>
        <p style="color:#fff; font-weight:900; font-size:1.1rem; margin:0 0 0.4rem; letter-spacing:-0.01em;">APEX <span style="font-weight:400; color:#8394b0;">Commercial Landscapes</span></p>
        <p style="font-size:0.78rem; line-height:1.65; margin:0 0 1rem; color:rgba(255,255,255,0.45);">Commercial-only landscape management for San Diego property managers since 1998. One vendor, one SLA, one invoice.</p>
        <p style="font-size:0.72rem; margin:0; color:rgba(255,255,255,0.4);">{co.address}</p>
      </div>
      <div>
        <p style="font-size:0.66rem; letter-spacing:0.2em; text-transform:uppercase; color:#8394b0; font-weight:700; margin:0 0 0.7rem;">Services</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.3rem; font-size:0.78rem;">
          <li><a href="#contracts" style="color:rgba(255,255,255,0.55); text-decoration:none;">Maintenance contracts</a></li>
          <li><a href="#services" style="color:rgba(255,255,255,0.55); text-decoration:none;">Service catalog</a></li>
          <li><a href="#portfolio" style="color:rgba(255,255,255,0.55); text-decoration:none;">Portfolio</a></li>
          <li><a href="#contact" style="color:rgba(255,255,255,0.55); text-decoration:none;">Request proposal</a></li>
        </ul>
      </div>
      <div>
        <p style="font-size:0.66rem; letter-spacing:0.2em; text-transform:uppercase; color:#8394b0; font-weight:700; margin:0 0 0.7rem;">Compliance</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.3rem; font-size:0.74rem; color:rgba(255,255,255,0.55); font-family:monospace;">
          <li>NALP Accredited &middot; 2018</li>
          <li>ISO 9001:2015</li>
          <li>DIR #1000000</li>
          <li>$5M GL &middot; $2M Auto</li>
          <li>OSHA 10 / 30 crews</li>
        </ul>
      </div>
      <div>
        <p style="font-size:0.66rem; letter-spacing:0.2em; text-transform:uppercase; color:#8394b0; font-weight:700; margin:0 0 0.7rem;">Resources</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.3rem; font-size:0.78rem;">
          <li><a href="#" style="color:rgba(255,255,255,0.55); text-decoration:none;">COI request</a></li>
          <li><a href="#" style="color:rgba(255,255,255,0.55); text-decoration:none;">W-9 / vendor packet</a></li>
          <li><a href="#" style="color:rgba(255,255,255,0.55); text-decoration:none;">Sustainability ESG</a></li>
          <li><a href="/accessibility" style="color:rgba(255,255,255,0.55); text-decoration:underline;">Accessibility</a></li>
        </ul>
      </div>
    </div>
    <p style="margin:1.25rem 0 0; font-size:0.7rem; color:rgba(255,255,255,0.3); display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; letter-spacing:0.03em;">
      <span>&copy; {new Date().getFullYear()} Apex Commercial Landscapes &middot; All SLAs in writing &middot; All rights reserved</span>
      <span>Built by <a href="https://dcrader.dev" style="color:rgba(255,255,255,0.55); text-decoration:underline;">Donovan Crader</a></span>
    </p>
  </div>
</footer>

</LandscapeLayout>
