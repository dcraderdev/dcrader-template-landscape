---
import { Image } from 'astro:assets';
import LandscapeLayout from '../layouts/LandscapeLayout.astro';
import { v5 as co } from '../data/company';
import { pic } from '../data/images';
const fonts = "https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,700;0,900;1,400&display=swap";
const heroImg = pic('1486325212027-8081e485255e');

const trustSignals = [
  { label: "$5M General Liability", icon: "🛡️" },
  { label: "Workers' Comp Insured", icon: "✅" },
  { label: "DIR Registered Contractor", icon: "📋" },
  { label: "OSHA 10 Certified Crews", icon: "⛑️" },
  { label: "ISO 9001 Quality System", icon: "🏆" },
  { label: "NALP Accredited Company", icon: "🎖️" },
];

const contractTiers = [
  {
    name: "Standard",
    price: "$495",
    period: "/mo per acre",
    sla: "48-hr response",
    features: ["Weekly grounds maintenance","Weed & pest control","Monthly inspection report","Dedicated account manager","Email + phone support"],
    highlight: false,
  },
  {
    name: "Professional",
    price: "$895",
    period: "/mo per acre",
    sla: "24-hr response",
    features: ["Weekly maintenance","Smart irrigation monitoring","Seasonal color rotations","Hardscape upkeep & pressure washing","QA inspection + photo report","Priority scheduling"],
    highlight: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    sla: "4-hr emergency SLA",
    features: ["Multi-site unified management","Custom SLA agreement","24/7 operations line","Dedicated crew assignment","Quarterly business reviews","Sustainability ESG reporting"],
    highlight: false,
  },
];
---

<LandscapeLayout
  title="Apex Commercial Landscapes — Commercial Maintenance Contracts, San Diego"
  description="Apex Commercial Landscapes manages office parks, retail centers, HOAs, and hospitality properties across greater San Diego. NALP accredited, ISO 9001 certified."
  fonts={fonts}
>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'Archivo', sans-serif; background: #fff; color: #0d1b3e; margin: 0; }

  :root {
    --navy: #0d1b3e;
    --navy-mid: #1a2d5a;
    --navy-light: #2a3f70;
    --silver: #8394b0;
    --silver-light: #c8d4e8;
    --bg: #ffffff;
    --bg2: #f4f7fb;
    --text: #0d1b3e;
    --muted: #6a7a90;
    --border: #c0ccd8;
  }

  .btn-navy {
    display: inline-block;
    background: #0d1b3e;
    color: #fff;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: background 0.18s;
    border: none;
    cursor: pointer;
  }
  .btn-navy:hover { background: #0a1530; }
  .btn-outline-navy {
    display: inline-block;
    background: transparent;
    color: #0d1b3e;
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.875rem 2rem;
    border: 2px solid #0d1b3e;
    text-decoration: none;
    transition: all 0.18s;
  }
  .btn-outline-navy:hover { background: #0d1b3e; color: #fff; }
  .btn-white {
    display: inline-block;
    background: #fff;
    color: #0d1b3e;
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.9rem 2rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.18s;
  }
  .btn-white:hover { opacity: 0.92; }
  .label { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #8394b0; margin-bottom: 0.6rem; }
  .card { background: #f4f7fb; border: 1px solid #c0ccd8; padding: 1.75rem; }
  section { padding: 5rem 2rem; }
  .inner { max-width: 80rem; margin: 0 auto; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 0.875rem 1rem; border-bottom: 1px solid #c0ccd8; font-size: 0.88rem; }
  th { background: #0d1b3e; color: #fff; font-weight: 700; letter-spacing: 0.04em; font-size: 0.78rem; text-transform: uppercase; }
  tr:hover td { background: #f4f7fb; }
</style>

<!-- TRUST BAR -->
<div style="background:#0d1b3e; padding:0.6rem 2rem; overflow-x:auto;">
  <div style="max-width:80rem; margin:0 auto; display:flex; gap:2.5rem; align-items:center; white-space:nowrap;">
    {trustSignals.map(t => (
      <span style="color:rgba(255,255,255,0.65); font-size:0.75rem; display:flex; align-items:center; gap:0.4rem; flex-shrink:0;">
        <span aria-hidden="true">{t.icon}</span> {t.label}
      </span>
    ))}
  </div>
</div>

<!-- NAV -->
<header style="background:#fff; border-bottom:1px solid #c0ccd8; position:sticky; top:0; z-index:50;">
  <nav aria-label="Main navigation" style="max-width:80rem; margin:0 auto; padding:1rem 2rem; display:flex; align-items:center; justify-content:space-between;">
    <a href="#" style="text-decoration:none; display:flex; align-items:center; gap:0.75rem;">
      <div style="width:36px; height:36px; background:#0d1b3e; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="10" width="16" height="8" rx="1" stroke="#8394b0" stroke-width="1.5"/><rect x="5" y="4" width="10" height="8" rx="1" stroke="#c8d4e8" stroke-width="1.5"/><rect x="8" y="1" width="4" height="5" rx="1" stroke="#fff" stroke-width="1.5"/></svg>
      </div>
      <div>
        <span style="font-weight:900; font-size:1.05rem; color:#0d1b3e; display:block; line-height:1.1; letter-spacing:-0.01em;">APEX</span>
        <span style="color:#8394b0; font-size:0.58rem; letter-spacing:0.18em; text-transform:uppercase; display:block;">Commercial Landscapes</span>
      </div>
    </a>
    <div style="display:flex; gap:2rem; align-items:center;">
      <a href="#services" style="color:#6a7a90; text-decoration:none; font-size:0.85rem; font-weight:500;">Services</a>
      <a href="#contracts" style="color:#6a7a90; text-decoration:none; font-size:0.85rem; font-weight:500;">Contracts</a>
      <a href="#portfolio" style="color:#6a7a90; text-decoration:none; font-size:0.85rem; font-weight:500;">Portfolio</a>
      <a href="#contact" class="btn-navy" style="padding:0.6rem 1.5rem; font-size:0.85rem;">Request Proposal</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO — aerial shot, corporate -->
<section aria-label="Hero" style="min-height:86vh; background:#0a1020; position:relative; overflow:hidden; display:flex; align-items:flex-end; padding:0;">
  <Image src={heroImg} alt="Aerial view of maintained commercial office park grounds" widths={[768, 1280, 1800, 2400]} sizes="100vw" loading="eager" fetchpriority="high" decoding="async" format="webp" quality={78} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.42;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(10,16,32,0.95) 0%, rgba(10,16,32,0.45) 55%, rgba(10,16,32,0.15) 100%);"></div>
  <!-- content -->
  <div style="position:relative; z-index:1; max-width:80rem; margin:0 auto; padding:0 2rem 5rem; width:100%; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:end;">
    <div>
      <p style="color:#8394b0; font-size:0.72rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.25rem;">Serving 185+ commercial accounts</p>
      <h1 style="color:#fff; font-size:clamp(2.5rem,5.5vw,4.25rem); font-weight:900; line-height:1.05; margin:0 0 1.25rem; letter-spacing:-0.02em;">
        Professional Property.<br /><span style="color:#8394b0;">Premium Presentation.</span>
      </h1>
      <p style="color:rgba(255,255,255,0.65); font-size:1rem; line-height:1.8; max-width:34rem; margin-bottom:2rem; font-weight:400;">
        Commercial landscape management for office campuses, retail centers, HOAs, and hospitality properties across greater San Diego. One call. One company. Total accountability.
      </p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap;">
        <a href="#contact" class="btn-white">Request Proposal</a>
        <a href="#contracts" style="color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.9rem; font-weight:500; display:flex; align-items:center; gap:0.4rem; padding:0.9rem 0;">View Contract Tiers →</a>
      </div>
    </div>
    <!-- Stats -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.08);">
      {co.stats.map(s => (
        <div style="background:#0a1020; padding:1.5rem; text-align:center;">
          <p style="color:#fff; font-size:2rem; font-weight:900; margin:0 0 0.25rem; letter-spacing:-0.02em;">{s.value}</p>
          <p style="color:#8394b0; font-size:0.72rem; margin:0; text-transform:uppercase; letter-spacing:0.1em; font-weight:500;">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PROPERTY TYPES STRIP -->
<section style="background:#f4f7fb; padding:2.5rem 2rem;">
  <div class="inner" style="display:flex; gap:0; flex-wrap:wrap; justify-content:space-between; align-items:center;">
    {[
      { icon: '🏢', label: 'Office Parks' },
      { icon: '🛍️', label: 'Retail Centers' },
      { icon: '🏨', label: 'Hospitality' },
      { icon: '🏘️', label: 'HOA Communities' },
      { icon: '🏗️', label: 'Industrial' },
      { icon: '🏛️', label: 'Municipal' },
    ].map(p => (
      <div style="text-align:center; padding:0.75rem 1.5rem; flex:1; min-width:120px;">
        <span style="font-size:2rem; display:block;" aria-hidden="true">{p.icon}</span>
        <span style="font-size:0.75rem; font-weight:700; color:#6a7a90; text-transform:uppercase; letter-spacing:0.1em;">{p.label}</span>
      </div>
    ))}
  </div>
</section>

<!-- SERVICES -->
<section id="services" aria-labelledby="svc-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:280px 1fr; gap:5rem; align-items:start;">
      <div>
        <span class="label">What we provide</span>
        <h2 id="svc-h" style="font-size:2.25rem; font-weight:900; margin:0.25rem 0 1.25rem; letter-spacing:-0.02em;">Commercial services</h2>
        <p style="color:#6a7a90; line-height:1.75; font-size:0.9rem; margin-bottom:1.5rem;">Scalable programs with dedicated account managers, monthly reporting, and performance SLAs.</p>
        <a href="#contact" class="btn-navy">Get a Proposal</a>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1px; background:#c0ccd8; border:1px solid #c0ccd8;">
        {co.services.map((s, i) => (
          <div style={`background:${i%2===0?'#fff':'#f4f7fb'}; padding:1.5rem;`}>
            <span style="font-size:1.75rem; display:block; margin-bottom:0.75rem;" aria-hidden="true">{s.icon}</span>
            <h3 style="font-size:0.95rem; font-weight:700; margin:0 0 0.4rem; color:#0d1b3e;">{s.title}</h3>
            <p style="color:#6a7a90; font-size:0.85rem; line-height:1.65; margin:0;">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- SNOW & ICE FEATURE -->
<section style="background:#0d1b3e; padding:5rem 2rem;">
  <div class="inner" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:3rem; align-items:center;">
    <div>
      <span class="label" style="color:#8394b0;">Seasonal specialty</span>
      <h2 style="color:#fff; font-size:2.25rem; font-weight:900; margin:0.25rem 0 1rem; letter-spacing:-0.02em;">Snow &amp; ice<br />management</h2>
      <p style="color:rgba(255,255,255,0.6); line-height:1.8; font-size:0.95rem; margin-bottom:1.5rem;">For Northern California commercial clients, we provide pre-treatment, de-icing, salting, and snow removal with 4-hour response SLAs. Keep your property open and your tenants safe.</p>
      <ul style="list-style:none; padding:0; margin:0 0 2rem; display:flex; flex-direction:column; gap:0.6rem;">
        {['Pre-storm salt application', 'Anti-icing liquid pre-treatment', 'Snow plowing & hauling', 'Walkway hand-clearing', 'Post-storm inspection', '4-hr response SLA guarantee'].map(f => (
          <li style="display:flex; gap:0.6rem; font-size:0.9rem; color:rgba(255,255,255,0.8); align-items:flex-start;">
            <span style="color:#8394b0; flex-shrink:0;" aria-hidden="true">❄️</span> {f}
          </li>
        ))}
      </ul>
      <a href="#contact" class="btn-white">Add to your contract</a>
    </div>
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); padding:2.5rem; text-align:center;">
      <span style="font-size:5rem; display:block; margin-bottom:1rem;" aria-hidden="true">❄️</span>
      <p style="color:rgba(255,255,255,0.5); font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; margin:0 0 1.5rem;">Available for</p>
      {['Sacramento Valley','Central Valley','Inland Empire','Tahoe-area properties'].map(loc => (
        <p style="color:#fff; font-size:0.9rem; margin:0 0 0.5rem; font-weight:500;">{loc}</p>
      ))}
    </div>
  </div>
</section>

<!-- CONTRACT TIERS -->
<section id="contracts" aria-labelledby="contracts-h" style="background:#f4f7fb; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3.5rem;">
      <span class="label">Maintenance contracts</span>
      <h2 id="contracts-h" style="font-size:2.5rem; font-weight:900; margin:0.25rem 0 0.75rem; letter-spacing:-0.02em;">Landscape maintenance programs</h2>
      <p style="color:#6a7a90; max-width:36rem; margin:0 auto; line-height:1.75; font-size:0.92rem;">All contracts include a dedicated account manager, monthly QA inspection, and photo report. SLA guarantees are in writing.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; align-items:start;">
      {contractTiers.map(t => (
        <div style={`background:${t.highlight?'#0d1b3e':'#fff'}; border:${t.highlight?'2px solid #0d1b3e':'1px solid #c0ccd8'}; padding:2rem; ${t.highlight?'transform:translateY(-6px);':''}`}>
          {t.highlight && <p style="font-size:0.68rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#8394b0; margin:0 0 0.75rem;">Most Popular</p>}
          <h3 style={`font-size:1.3rem; font-weight:900; margin:0 0 0.25rem; letter-spacing:-0.01em; ${t.highlight?'color:#fff;':''}`}>{t.name}</h3>
          <p style={`font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1rem; ${t.highlight?'color:#8394b0;':'color:#8394b0;'}`}>SLA: {t.sla}</p>
          <div style="display:flex; align-items:baseline; gap:0.25rem; margin-bottom:1.5rem;">
            <span style={`font-size:2.75rem; font-weight:900; letter-spacing:-0.02em; ${t.highlight?'color:#fff;':'color:#0d1b3e;'}`}>{t.price}</span>
            <span style={`font-size:0.85rem; ${t.highlight?'color:rgba(255,255,255,0.5);':'color:#6a7a90;'}`}>{t.period}</span>
          </div>
          <ul style="list-style:none; padding:0; margin:0 0 1.75rem; display:flex; flex-direction:column; gap:0.65rem;">
            {t.features.map(f => (
              <li style="display:flex; gap:0.6rem; font-size:0.875rem; align-items:flex-start; line-height:1.5;">
                <span style={`flex-shrink:0; font-weight:700; ${t.highlight?'color:#8394b0;':'color:#0d1b3e;'}`} aria-hidden="true">✓</span>
                <span style={t.highlight?'color:rgba(255,255,255,0.85);':''}>{f}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class="btn-navy" style={`display:block; text-align:center; ${t.highlight?'background:#fff; color:#0d1b3e;':''}`}>Request Proposal</a>
        </div>
      ))}
    </div>
    <!-- SLA table -->
    <div style="margin-top:2.5rem; overflow-x:auto;">
      <table>
        <caption style="text-align:left; font-size:0.78rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#6a7a90; padding-bottom:0.75rem;">Service Level Comparison</caption>
        <thead>
          <tr>
            <th>Feature</th>
            <th>Standard</th>
            <th>Professional</th>
            <th>Enterprise</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Response SLA', '48 hours', '24 hours', '4 hours'],
            ['Account Manager', '✓', '✓', 'Dedicated senior'],
            ['Reporting', 'Monthly', 'Monthly + photos', 'Custom dashboard'],
            ['Multi-site support', '—', '—', '✓'],
            ['Emergency line', '—', '✓', '24/7 direct'],
            ['Sustainability report', '—', '—', 'Quarterly ESG'],
          ].map(row => (
            <tr>
              {row.map((cell, ci) => (
                ci === 0
                  ? <td style="font-weight:600; color:#0d1b3e;">{cell}</td>
                  : <td style="color:#6a7a90;">{cell}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- PORTFOLIO -->
<section id="portfolio" aria-labelledby="port-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">Client showcase</span>
      <h2 id="port-h" style="font-size:2.25rem; font-weight:900; margin:0.25rem 0; letter-spacing:-0.02em;">Selected accounts</h2>
    </div>
    <div class="gallery-grid">
      {co.portfolio.map(p => (
        <figure style="margin:0; border:1px solid #c0ccd8; background:#f4f7fb;">
          <div class="gallery-tile" style="border-radius:0;">
            <Image src={pic(p.img)} alt={p.title} widths={[400, 600, 900]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" loading="lazy" decoding="async" format="webp" quality={75} />
          </div>
          <figcaption style="padding:1.5rem;">
            <h3 style="font-weight:700; font-size:1rem; margin:0 0 0.35rem; color:#0d1b3e;">{p.title}</h3>
            <p style="color:#6a7a90; font-size:0.875rem; margin:0; line-height:1.6;">{p.description}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- BEFORE/AFTER -->
<section aria-labelledby="ba-h" style="background:#f4f7fb; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">Property transformations</span>
      <h2 id="ba-h" style="font-size:2.25rem; font-weight:900; margin:0.25rem 0; letter-spacing:-0.02em;">Before &amp; after</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(360px,1fr)); gap:2rem;">
      {co.beforeAfter.map(ba => (
        <div>
          <h3 style="font-weight:700; font-size:0.95rem; margin-bottom:1rem; color:#0d1b3e;">{ba.label}</h3>
          <div class="ba-pair">
            <figure>
              <Image src={pic(ba.before)} alt={`Before: ${ba.label}`} widths={[300, 600]} sizes="(min-width: 1024px) 25vw, 50vw" loading="lazy" decoding="async" format="webp" quality={72} />
              <span style="position:absolute; top:0.5rem; left:0.5rem; font-size:0.66rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:rgba(13,27,62,0.7); padding:0.25rem 0.55rem;">Before</span>
            </figure>
            <figure>
              <Image src={pic(ba.after)} alt={`After: ${ba.label}`} widths={[300, 600]} sizes="(min-width: 1024px) 25vw, 50vw" loading="lazy" decoding="async" format="webp" quality={72} />
              <span style="position:absolute; top:0.5rem; left:0.5rem; font-size:0.66rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:#fff; background:#0d1b3e; padding:0.25rem 0.55rem;">After</span>
            </figure>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TEAM -->
<section aria-labelledby="team-h" style="background:#fff; padding:5rem 2rem;">
  <div class="inner">
    <div style="text-align:center; margin-bottom:3rem;">
      <span class="label">Leadership</span>
      <h2 id="team-h" style="font-size:2rem; font-weight:900; margin:0.25rem 0; letter-spacing:-0.02em;">Our team</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:1.5rem;">
      {co.teamMembers.map(m => (
        <div class="card" style="text-align:center;">
          <div style="width:68px; height:68px; background:#0d1b3e; margin:0 auto 1rem; display:flex; align-items:center; justify-content:center;" aria-hidden="true">
            <span style="color:#8394b0; font-size:1.5rem; font-weight:900;">{m.name[0]}</span>
          </div>
          <h3 style="font-weight:700; font-size:0.95rem; margin:0 0 0.25rem; color:#0d1b3e;">{m.name}</h3>
          <p style="color:#6a7a90; font-size:0.82rem; margin:0;">{m.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- B2B TRUST SIGNALS -->
<section aria-labelledby="trust-h" style="background:#f4f7fb; padding:4rem 2rem;">
  <div class="inner">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2.5rem; align-items:center;">
      <div>
        <span class="label">Standards &amp; compliance</span>
        <h2 id="trust-h" style="font-size:2rem; font-weight:900; margin:0.25rem 0 1rem; letter-spacing:-0.02em;">Why property managers choose Apex</h2>
        <p style="color:#6a7a90; line-height:1.75; font-size:0.9rem;">Every contract includes written SLAs, $5M liability coverage, OSHA-compliant crews, and DIR-registered labor. We carry the risk — so you don't have to.</p>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        {trustSignals.map(t => (
          <div style="background:#fff; border:1px solid #c0ccd8; padding:1rem; display:flex; align-items:center; gap:0.75rem;">
            <span style="font-size:1.5rem;" aria-hidden="true">{t.icon}</span>
            <span style="font-size:0.82rem; font-weight:600; color:#0d1b3e; line-height:1.35;">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CONTACT — RFP FORM -->
<section id="contact" aria-labelledby="contact-h" style="background:#0a1020; padding:5rem 2rem;">
  <div style="max-width:50rem; margin:0 auto; text-align:center;">
    <span class="label" style="color:#8394b0;">Start a proposal</span>
    <h2 id="contact-h" style="color:#fff; font-size:2.5rem; font-weight:900; margin:0.35rem 0 0.75rem; letter-spacing:-0.02em;">Request a landscape proposal</h2>
    <p style="color:rgba(255,255,255,0.55); margin-bottom:2.5rem; line-height:1.75; font-size:0.92rem;">We conduct a property walk, assess your current landscape, and deliver a custom maintenance proposal within 3 business days.</p>
    <form novalidate aria-label="Commercial landscape proposal request" style="display:grid; gap:1rem; text-align:left;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div>
          <label for="v5-fn" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">First name <span aria-hidden="true">*</span></label>
          <input id="v5-fn" name="first_name" type="text" required autocomplete="given-name" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
        </div>
        <div>
          <label for="v5-ln" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Last name <span aria-hidden="true">*</span></label>
          <input id="v5-ln" name="last_name" type="text" required autocomplete="family-name" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
        </div>
      </div>
      <div>
        <label for="v5-co" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Company / Property name <span aria-hidden="true">*</span></label>
        <input id="v5-co" name="company" type="text" required autocomplete="organization" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" placeholder="Acme Properties LLC" />
      </div>
      <div>
        <label for="v5-email" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Email <span aria-hidden="true">*</span></label>
        <input id="v5-email" name="email" type="email" required autocomplete="email" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;" />
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div>
          <label for="v5-type" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Property type</label>
          <select id="v5-type" name="property_type" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(10,16,32,0.98); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;">
            <option value="">Select…</option>
            <option>Office Campus / Park</option>
            <option>Retail Center</option>
            <option>Hotel / Hospitality</option>
            <option>HOA / Multi-Family</option>
            <option>Industrial / Flex</option>
            <option>Municipal / Government</option>
          </select>
        </div>
        <div>
          <label for="v5-tier" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Contract tier interest</label>
          <select id="v5-tier" name="tier" style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(10,16,32,0.98); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif;">
            <option value="">Not sure</option>
            {contractTiers.map(t => <option value={t.name}>{t.name}</option>)}
          </select>
        </div>
      </div>
      <div>
        <label for="v5-details" style="color:rgba(255,255,255,0.65); font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; display:block; margin-bottom:0.4rem;">Property details</label>
        <textarea id="v5-details" name="details" rows={4} style="width:100%; padding:0.75rem; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); color:#fff; font-size:0.9rem; font-family:'Archivo',sans-serif; resize:vertical;" placeholder="Square footage, number of sites, current provider, key pain points…"></textarea>
      </div>
      <button type="submit" class="btn-white" style="width:100%; padding:1.1rem; font-size:0.95rem; font-weight:700;">Submit for Proposal →</button>
    </form>
    <p style="color:rgba(255,255,255,0.3); font-size:0.78rem; margin-top:1.5rem;">{co.phone} · {co.email} · proposals delivered within 3 business days</p>
  </div>
</section>

</main>

<footer style="background:#050d1a; color:rgba(255,255,255,0.35); padding:3rem 2rem; text-align:center;">
  <div style="max-width:80rem; margin:0 auto;">
    <p style="color:rgba(255,255,255,0.65); font-weight:900; font-size:1rem; margin-bottom:0.4rem; letter-spacing:-0.01em;">APEX Commercial Landscapes</p>
    <p style="font-size:0.78rem; margin-bottom:0.35rem;">{co.address} · {co.phone} · {co.email}</p>
    <p style="font-size:0.72rem;">&copy; {new Date().getFullYear()} Apex Commercial Landscapes. NALP Accredited. ISO 9001. DIR #1000000. All rights reserved.</p>
  </div>
</footer>

</LandscapeLayout>
