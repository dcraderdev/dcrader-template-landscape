---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  fonts?: string;
  image?: string;
}

const {
  title,
  description = 'Modern websites for landscape, lawn, and tree services.',
  fonts,
  image = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://dcrader-template-landscape.vercel.app');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Landscape Template Collection" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {fonts && <link href={fonts} rel="stylesheet" />}
    <slot name="head" />
    <script src="/template-topheader.js" defer></script>
    <style is:global>
      html { scroll-padding-top: 40px !important; }
      body { padding-top: 36px !important; }
      body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
    </style>
  </head>
  <body>
    <a href="#main-content" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;" onfocus="this.style.cssText='position:fixed;top:1rem;left:1rem;z-index:9999;padding:0.5rem 1rem;background:white;color:black;font-weight:700;border-radius:4px;text-decoration:none;width:auto;height:auto;overflow:visible;'">
      Skip to main content
    </a>
    <slot />
    <script>
      if (import.meta.env.DEV) {
        import('axe-core').then(({ default: axe }) => {
          axe.run().then(results => {
            if (results.violations.length) {
              console.group('%c axe violations', 'color:red;font-weight:bold');
              results.violations.forEach(v => console.error(v.id, v.description, v.nodes));
              console.groupEnd();
            } else {
              console.log('%c axe: 0 violations', 'color:green;font-weight:bold');
            }
          });
        });
      }
    </script>
  </body>
</html>
