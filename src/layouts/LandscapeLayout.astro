---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  primaryColor: string;
  secondaryColor: string;
}

const { title, description, primaryColor, secondaryColor } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">
      Skip to main content
    </a>
    <slot />
    <script>
      // Run axe-core in development
      if (import.meta.env.DEV) {
        import('axe-core').then(({ default: axe }) => {
          axe.run().then(results => {
            if (results.violations.length) {
              console.group('%c Accessibility Violations', 'color:red;font-weight:bold');
              results.violations.forEach(v => console.error(v));
              console.groupEnd();
            } else {
              console.log('%c No axe violations found', 'color:green;font-weight:bold');
            }
          });
        });
      }
    </script>
  </body>
</html>
