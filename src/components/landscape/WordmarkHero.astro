---
/**
 * WordmarkHero — variant 1 treatment.
 *
 * A typographic brand mark dominates the hero. No background photo —
 * the company name is rendered as an oversized serif wordmark with a
 * vertical accent rule and stenciled monogram. Designed to read as a
 * neighborhood family-shop signage piece for residential lawn care.
 */
interface Props {
  brand: string;
  tagline: string;
  founded?: number;
  ctaPrimary?: { href: string; label: string };
  ctaSecondary?: { href: string; label: string };
  rating?: { stars: number; count: number };
}
const {
  brand,
  tagline,
  founded,
  ctaPrimary = { href: '#contact', label: 'Get free quote' },
  ctaSecondary = { href: '#plans', label: 'See plans' },
  rating,
} = Astro.props as Props;

const monogram = brand
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map(w => w[0])
  .join('')
  .toUpperCase();
---

<section aria-label="Hero" style="background:#faf8f3; padding:0; position:relative; overflow:hidden;">
  <div style="max-width:80rem; margin:0 auto; padding:6rem 2rem 5rem; display:grid; grid-template-columns:auto 1fr; gap:3.5rem; align-items:center;">
    <!-- Monogram plate -->
    <div aria-hidden="true" style="display:flex; flex-direction:column; align-items:center; gap:1rem; padding:1rem 0; border-right:1px solid #c8a84b;">
      <span class="serif" style="font-family:'IBM Plex Serif',Georgia,serif; font-size:6rem; line-height:1; font-weight:700; color:#2a5f2a; letter-spacing:-0.04em; padding-right:2rem;">{monogram}</span>
      {founded && <span style="font-size:0.65rem; letter-spacing:0.22em; text-transform:uppercase; color:#637063; padding-right:2rem;">Est. {founded}</span>}
    </div>

    <!-- Wordmark + meta -->
    <div>
      <p style="font-size:0.7rem; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:#3d7a3d; margin:0 0 1.25rem;">
        — Neighborhood lawn care, since {founded ?? 2004}
      </p>
      <h1 class="serif" style="font-family:'IBM Plex Serif',Georgia,serif; font-size:clamp(3rem, 8vw, 6.5rem); line-height:0.92; font-weight:700; color:#1c2b1a; margin:0 0 1rem; letter-spacing:-0.025em;">
        {brand}
      </h1>
      <p class="serif" style="font-family:'IBM Plex Serif',Georgia,serif; font-style:italic; font-size:1.5rem; color:#3d7a3d; margin:0 0 2rem; max-width:36rem; line-height:1.4;">
        {tagline}
      </p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
        <a href={ctaPrimary.href} style="display:inline-block; background:#2a5f2a; color:#fff; font-weight:700; font-size:0.95rem; padding:0.95rem 2.2rem; border-radius:6px; text-decoration:none;">{ctaPrimary.label}</a>
        <a href={ctaSecondary.href} style="display:inline-block; color:#2a5f2a; font-weight:600; font-size:0.95rem; padding:0.9rem 0; text-decoration:underline; text-underline-offset:5px;">{ctaSecondary.label} →</a>
        {rating && (
          <span style="margin-left:auto; display:flex; align-items:center; gap:0.5rem; padding-left:1.5rem; border-left:1px solid #dde8dd;">
            <span aria-hidden="true" style="color:#c8a84b; font-size:1.1rem;">★★★★★</span>
            <span style="font-weight:700; color:#1c2b1a;">{rating.stars}</span>
            <span style="color:#637063; font-size:0.85rem;">({rating.count} reviews)</span>
          </span>
        )}
      </div>
    </div>
  </div>

  <!-- Bottom rule -->
  <div style="border-top:1px solid #dde8dd; padding:1.25rem 2rem; max-width:80rem; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
    <span style="font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; color:#637063;">A wordmark by the crew · printed on every invoice</span>
    <span style="font-family:'IBM Plex Serif',Georgia,serif; font-style:italic; font-size:0.85rem; color:#3d7a3d;">Same name on the truck. Same name on your lawn.</span>
  </div>
</section>
